---
/**
 * TornDivider, a hand-torn paper strip between sections.
 * `variant` (a|b|c) varies the rotation + noise so repeats feel hand-placed.
 */
interface Props {
  variant?: "a" | "b" | "c";
}
const { variant = "a" } = Astro.props;
const seed = variant === "a" ? 7 : variant === "b" ? 23 : 41;
const freq = variant === "a" ? "0.014 0.05" : variant === "b" ? "0.018 0.04" : "0.02 0.045";
const filterId = `torn-${variant}-${Math.random().toString(36).slice(2, 7)}`;
---
<div class={`torn torn-${variant}`} aria-hidden="true">
  <svg viewBox="0 0 1200 54" preserveAspectRatio="none">
    <defs>
      <filter id={filterId} x="-5%" y="-60%" width="110%" height="220%">
        <feTurbulence type="fractalNoise" baseFrequency={freq} numOctaves="3" seed={seed} result="n" />
        <feDisplacementMap in="SourceGraphic" in2="n" scale="26" xChannelSelector="R" yChannelSelector="G" />
      </filter>
    </defs>
    <rect x="-30" y="20" width="1260" height="16" fill="#F3EEE1" filter={`url(#${filterId})`}></rect>
  </svg>
</div>
