---
/**
 * ArticleCard, a row in the feed / latest list, styled as a torn note.
 */
import { type Article } from "../lib/types";

interface Props {
  article: Article;
}
const { article } = Astro.props;
const dirs = article.directions ?? [];
const dateNice = article.published_at || article.published_date
  ? new Date(article.published_at ?? article.published_date!).toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
    })
  : "";
const metaBits = [
  dirs[0]?.name,
  article.difficulty,
].filter(Boolean);
---

<a class="note-row" href={`/article/${article.slug}`} data-reveal>
  <span class="date">{dateNice}</span>
  <span class="nr-main">
    <span class="title">{article.plain_title}</span><br />
    <span class="meta">{metaBits.join(" · ")}{article.is_ai4good === 1 ? " · AI for Good" : ""}</span>
  </span>
  <span class="arr">→</span>
</a>
