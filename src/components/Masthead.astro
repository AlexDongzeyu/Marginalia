---
/**
 * Masthead, newspaper nameplate with rules above/below.
 */
interface Props {
  title: string;
  tagline?: string;
  top?: string;
  bottom?: string;
  compact?: boolean;
}
const { title, compact = false } = Astro.props;
---
<section class={`masthead ${compact ? "compact" : ""}`}>
  <h1>{title}</h1>
</section>
