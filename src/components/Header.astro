---
/**
 * Sticky paper-tab nav, rotated paper chips on the desk.
 * Primary tabs mirror the mockup; everything else is reachable from the footer.
 * Reads the session cookie so the nav reflects the logged-in member.
 */
import { getSessionUserId, getUserById } from "../lib/auth";

const path = Astro.url.pathname;

// Top nav resolves to the four programs, plus Today (the daily habit) and About.
// Each program "owns" a set of routes so its tab stays lit while you're inside it.
const tabs = [
  { href: "/today", label: "Today", match: ["/today"] },
  { href: "/press", label: "Press", match: ["/press", "/feed", "/map", "/glossary", "/pulse", "/article"] },
  { href: "/learn", label: "Learn", match: ["/learn"] },
  { href: "/lab", label: "Lab", match: ["/lab", "/projects", "/datasets"] },
  { href: "/commons", label: "Commons", match: ["/commons", "/chapters", "/newsletter"] },
  { href: "/about", label: "About", match: ["/about"] },
];
const tabActive = (matches: string[]) =>
  matches.some((m) => (m === "/" ? path === "/" : path === m || path.startsWith(m + "/") || path.startsWith(m)));

// Full directory for the "More" dropdown, grouped by program.
const moreGroups = [
  {
    title: "Press",
    href: "/press",
    links: [
      { href: "/today", label: "Today's paper" },
      { href: "/feed", label: "The feed" },
      { href: "/map", label: "The map" },
      { href: "/glossary", label: "Glossary" },
      { href: "/pulse", label: "Pulse" },
    ],
  },
  {
    title: "Learn",
    href: "/learn",
    links: [
      { href: "/learn", label: "Tracks & lessons" },
      { href: "/glossary", label: "Glossary" },
    ],
  },
  {
    title: "Lab",
    href: "/lab",
    links: [
      { href: "/projects", label: "Projects" },
      { href: "/contribute/explain", label: "Explain & research" },
      { href: "/datasets", label: "Datasets" },
    ],
  },
  {
    title: "Commons",
    href: "/commons",
    links: [
      { href: "/chapters", label: "Chapters" },
      { href: "/chapters/start", label: "Start a chapter" },
      { href: "/contribute/classify", label: "Classify" },
      { href: "/newsletter", label: "Newsletter" },
    ],
  },
  {
    title: "Org & you",
    links: [
      { href: "/about", label: "About & team" },
      { href: "/contribute", label: "All the ways to help" },
      { href: "/join", label: "Join" },
      { href: "/dashboard", label: "Your library" },
      { href: "/login", label: "Sign in" },
    ],
  },
];

let user: { id: number; name: string; role: string } | null = null;
try {
  const env = Astro.locals.runtime?.env;
  if (env) {
    const uid = await getSessionUserId(Astro.request.headers.get("cookie"), env);
    if (uid) user = await getUserById(env.DB, uid);
  }
} catch {
  user = null;
}
const firstName = user ? user.name.split(/\s+/)[0] || user.name : "";
const initials = user
  ? user.name
      .split(/\s+/)
      .map((p) => p[0])
      .filter(Boolean)
      .slice(0, 2)
      .join("")
      .toUpperCase()
  : "";
---

<div class="paper-nav">
  <div class="paper-nav-inner">
    <a href="/" class="nav-brand" aria-label="Marginalia home">
      Marginalia<span class="daily">daily</span>
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">&#9776;</button>

    <nav class="nav-tabs" id="navTabs" aria-label="Primary">
      {tabs.map((t) => (
        <a href={t.href} class={`nav-tab ${tabActive(t.match) ? "active" : ""}`}>{t.label}</a>
      ))}

      <div class="nav-more" id="navMore">
        <button
          class="nav-tab nav-more-btn"
          id="navMoreBtn"
          type="button"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="navDropdown"
        >More <span class="nav-more-caret" aria-hidden="true">▾</span></button>
        <div class="nav-dropdown" id="navDropdown" role="menu" aria-label="All pages">
          {moreGroups.map((g) => (
            <div class="nav-dd-group">
              {g.href ? (
                <a class="nav-dd-title nav-dd-title-link" href={g.href} role="menuitem">{g.title}</a>
              ) : (
                <div class="nav-dd-title">{g.title}</div>
              )}
              {g.links.map((l) => (
                <a
                  href={l.href}
                  class={`nav-dd-link ${path === l.href ? "active" : ""}`}
                  role="menuitem"
                >{l.label}</a>
              ))}
            </div>
          ))}
        </div>
      </div>

      {user ? (
        <span class="nav-account">
          <a
            href="/dashboard"
            class={`nav-user ${path.startsWith("/dashboard") ? "active" : ""}`}
            aria-label={`Account: ${user.name}`}
          >
            <span class="nav-ava" aria-hidden="true">{initials}</span>
            <span class="nav-uname">{firstName}</span>
          </a>
          {(user.role === "admin" || user.role === "editor") && (
            <a href="/admin" class={`nav-admin ${path.startsWith("/admin") ? "active" : ""}`}>Admin</a>
          )}
          <a href="/api/auth/logout" class="nav-out">Sign&nbsp;out</a>
        </span>
      ) : (
        <a href="/login" class="nav-signin">Sign&nbsp;in</a>
      )}
    </nav>
  </div>
</div>

<script>
  const toggle = document.getElementById("navToggle");
  const tabs = document.getElementById("navTabs");
  toggle?.addEventListener("click", () => {
    const open = tabs?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", open ? "true" : "false");
  });

  // "All pages" dropdown: tap to toggle, click-away or Escape to close.
  const more = document.getElementById("navMore");
  const moreBtn = document.getElementById("navMoreBtn");
  const closeMore = () => {
    more?.classList.remove("open");
    moreBtn?.setAttribute("aria-expanded", "false");
  };
  moreBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    const open = more?.classList.toggle("open");
    moreBtn.setAttribute("aria-expanded", open ? "true" : "false");
  });
  document.addEventListener("click", (e) => {
    if (more?.classList.contains("open") && e.target instanceof Node && !more.contains(e.target)) {
      closeMore();
    }
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && more?.classList.contains("open")) {
      closeMore();
      moreBtn?.focus();
    }
  });
</script>
