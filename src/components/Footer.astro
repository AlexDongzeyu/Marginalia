---
/**
 * Site footer with quick-link columns + newsletter nudge.
 * Layout carried over from ECHOE; content swapped for Marginalia.
 */
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <div class="footer-section">
      <h4>Marginalia</h4>
      <p style="opacity:.85; max-width:36ch;">
        AI research, explained for newcomers. A free, student-run guide to the
        field — built around AI for good.
      </p>
      <p class="footer-extra" style="margin-top:12px; font-size:.85rem; opacity:.7;">
        AI-assisted summaries, reviewed by people. We link to every source.
      </p>
    </div>

    <div class="footer-section">
      <h4>Read</h4>
      <ul>
        <li><a href="/today">Article of the Day</a></li>
        <li><a href="/feed">The feed</a></li>
        <li><a href="/glossary">Glossary</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Explore</h4>
      <ul>
        <li><a href="/map">Research map</a></li>
        <li><a href="/directions">Directions</a></li>
        <li><a href="/learn">Learning tracks</a></li>
        <li><a href="/projects">Projects</a></li>
      </ul>
    </div>

    <div class="footer-section">
      <h4>Community</h4>
      <ul>
        <li><a href="/chapters">Chapters</a></li>
        <li><a href="/newsletter">Newsletter</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/join">Join us</a></li>
        <li><a href="/login">Login</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>
      &copy; {year} Marginalia &middot; A student-run, mission-driven project &middot;
      <a href="/about#integrity">Integrity &amp; sources</a>
    </p>
  </div>
</footer>
