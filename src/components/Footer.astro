---
/**
 * Footer — contact sheet. Four columns of links + a base line.
 */
const year = new Date().getFullYear();
---

<footer class="contact-footer">
  <div class="contact-grid">
    <div>
      <div class="brand">Marginalia</div>
      <p class="brand-note">Notes on the AI research that matters. Made by students, in the margins.</p>
    </div>
    <div class="contact-col">
      <h4>Read</h4>
      <div class="links">
        <a href="/today">Today's paper</a>
        <a href="/feed">The feed</a>
        <a href="/map">The research map</a>
        <a href="/glossary">Glossary</a>
      </div>
    </div>
    <div class="contact-col">
      <h4>Take part</h4>
      <div class="links">
        <a href="/chapters/start">Start a chapter</a>
        <a href="/dashboard">Your library</a>
        <a href="/join">Contribute a note</a>
        <a href="/newsletter">Newsletter</a>
      </div>
    </div>
    <div class="contact-col">
      <h4>Org</h4>
      <div class="links">
        <a href="/about">About &amp; team</a>
        <a href="/about#integrity">How we work</a>
        <a href="/login">Sign in</a>
      </div>
    </div>
  </div>
  <div class="contact-base">
    <span>&copy; {year} Marginalia · a student-run reading room</span>
    <span>We link to arXiv. We never republish. We just explain.</span>
  </div>
</footer>
