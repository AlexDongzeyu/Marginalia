---
/**
 * /article/[slug], "The Annotated Paper".
 * Center: explainer (from D1) with a Source-PDF toggle (arXiv embed).
 * Left margin: team explainer notes. Right margin: member notes + leaderboard.
 * Footer: an understanding quiz that awards a stamp (client-side demo).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedArticleBySlug, getRelatedArticles, getApprovedGlossary } from "../../lib/db";
import { renderMarkdown } from "../../lib/markdown";
import { getSessionUser } from "../../lib/auth";

const { slug } = Astro.params;
const { env } = Astro.locals.runtime;

const article = slug ? await getPublishedArticleBySlug(env.DB, slug) : null;
if (!article) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}
const dirs = article.directions ?? [];
const related = await getRelatedArticles(env.DB, article.id, dirs.map((d) => d.id), 3);

const me = await getSessionUser(Astro.request.headers.get("cookie"), env, env.DB);
const annRes = await env.DB
  .prepare(
    `SELECT id, author_name, body, created_at FROM annotations
     WHERE article_id = ? AND status = 'approved' ORDER BY created_at DESC LIMIT 40`,
  )
  .bind(article.id)
  .all();
const annotations = (annRes.results ?? []) as {
  id: number;
  author_name: string;
  body: string;
  created_at: string;
}[];

// Glossary terms tied to this paper, shown as plain-language explanations in
// the margin so the jargon stays out of the reading column.
let terms: { term: string; definition: string }[] = [];
try {
  const tr = await env.DB
    .prepare(
      `SELECT g.term, g.definition FROM glossary_terms g
       JOIN article_terms t ON t.term_id = g.id
       WHERE t.article_id = ? AND g.status = 'approved'
       ORDER BY g.term LIMIT 8`,
    )
    .bind(article.id)
    .all<{ term: string; definition: string }>();
  terms = tr.results ?? [];
} catch {
  terms = [];
}
const initialsOf = (n: string) =>
  n.split(/\s+/).map((w) => w[0]).filter(Boolean).slice(0, 2).join("").toUpperCase();

const whatsGoingOn = renderMarkdown(article.whats_going_on);
const whyItMatters = renderMarkdown(article.why_it_matters);
const diffClass = article.difficulty === "Beginner" ? "tag-beginner" : article.difficulty === "Advanced" ? "tag-advanced" : "tag-intermediate";
const pdfUrl = article.pdf_url || (article.arxiv_id ? `https://arxiv.org/pdf/${article.arxiv_id}` : null);
const hasPdf = !!pdfUrl;
// Same-origin proxy so the PDF actually renders inline (arXiv blocks iframing).
const pdfEmbed = article.arxiv_id ? `/api/pdf?id=${encodeURIComponent(article.arxiv_id)}` : pdfUrl;
// Plain-language glossary for the inline highlight-and-explain annotations.
const glossary = await getApprovedGlossary(env.DB).catch(() => []);
---

<BaseLayout title={`${article.plain_title} · Marginalia`} description={article.hook} bodyClass="page-article">
  <div class="sheet">
    <div class="sheet-pad">
      <!-- HEADER -->
      <div style="max-width:680px; margin:18px auto 8px; text-align:center;">
        <h1 style="font-size:clamp(34px,5vw,52px); line-height:1.04; letter-spacing:-0.02em; font-weight:600; margin:0 0 12px;">{article.plain_title}</h1>
        <p style="margin:0 0 4px; font-style:italic; font-size:16px; color:var(--ink-soft);">orig. “{article.original_title}”{article.authors.length ? ` · ${article.authors.join(", ")}` : ""}</p>
        <div class="row wrap gap-8 center" style="margin-top:14px;">
          {dirs[0] && <span class="tag tag-lm">{dirs[0].name}</span>}
          <span class={`tag ${diffClass}`}>{article.difficulty}</span>
          <span class="tag">{article.read_minutes} min read</span>
          <span class="tag" style="border:1px dashed var(--line-2);">{article.ai_model === "hand-written" ? "Written" : "AI-assisted"}, reviewed by {article.reviewer_name ?? "the team"}</span>
        </div>
      </div>

      <!-- 3-ZONE -->
      <section class="lmrow" style="--read-w:620px; align-items:start;">
        <!-- LEFT MARGIN: team explainer notes -->
        <div class="lmside left" style="padding-top:30px;">
          <div style="font-family:var(--mono); font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:var(--ink-faintest);">In the margin</div>
          {dirs[0] && (
            <div class="mn-card mn-tilt-l" data-reveal data-note="area">
              <div class="mn-label">Area</div>
              <div class="mn-body"><b>{dirs[0].name}</b>, {dirs[0].plain_description}</div>
            </div>
          )}
          {terms.map((t, i) => (
            <div class={`mn-card ${i % 2 ? "mn-tilt-r" : "mn-tilt-l"}`} data-reveal>
              <div class="mn-label">{t.term}</div>
              <div class="mn-body">{t.definition}</div>
            </div>
          ))}
        </div>

        <!-- CENTER: reader -->
        <div class="lmcenter">
          {hasPdf && (
            <div class="row gap-8 center" style="margin-bottom:14px;">
              <button id="modeExplainer" class="btn-ink" type="button">Explainer</button>
              <button id="modeSource" class="btn-outline" type="button">Source PDF</button>
            </div>
          )}

          <!-- EXPLAINER -->
          <div id="explainerPane">
            <div style="background:var(--paper); border:1px solid rgba(33,28,22,.1); padding:36px 40px; box-shadow:0 20px 50px -26px rgba(40,30,20,.4);">
              <p class="pullquote">{article.hook}</p>
              <div class="section-label">What's going on</div>
              <div class="read drop-cap"><Fragment set:html={whatsGoingOn} /></div>
              <div class="section-label" style="margin-top:24px;">Why it matters</div>
              <div class="read"><Fragment set:html={whyItMatters} /></div>
            </div>

            <!-- source box -->
            <div style="margin-top:18px; background:var(--card-2); border:1px solid rgba(122,92,62,.22); padding:16px 18px;">
              <div class="mn-label" style="color:var(--accent);">Source</div>
              <p style="margin:6px 0 10px; font-size:14px; color:var(--ink-soft);">
                {article.authors.join(", ")}{article.institution ? `, ${article.institution}` : ""}
              </p>
              <div class="row wrap gap-8">
                {article.source_url && <a class="btn-outline" href={article.source_url} target="_blank" rel="noopener noreferrer">{article.arxiv_id ? "View on arXiv ↗" : "View the paper ↗"}</a>}
                {pdfUrl && <a class="btn-outline" href={pdfUrl} target="_blank" rel="noopener noreferrer">PDF ↗</a>}
              </div>
              <p style="margin:12px 0 0; font-family:var(--mono); font-size:10px; color:var(--ink-faint); border-top:1px dashed var(--line-2); padding-top:10px;">
                We write original plain-language summaries and link to the source. We never republish the paper.
              </p>
            </div>

            <!-- explain-simpler assistant -->
            <div style="margin-top:18px; background:var(--card); border:1px solid var(--line); padding:18px 20px;">
              <div class="section-label" style="color:var(--accent-2);">Still fuzzy on a sentence?</div>
              <p style="margin:0 0 8px; font-size:14px; color:var(--ink-soft);">Paste it and we'll explain it even more simply.</p>
              <textarea id="explainInput" class="paper-textarea" rows="2" placeholder="Paste a sentence…"></textarea>
              <div class="mt-8"><button id="explainBtn" class="btn-outline" type="button">Explain it simpler</button></div>
              <div id="explainResult" class="hidden" style="margin-top:12px; background:var(--paper); border:1px solid var(--line); padding:14px; font-size:15px; line-height:1.6;"></div>
            </div>
          </div>

          <!-- SOURCE PDF -->
          {hasPdf && (
            <div id="sourcePane" class="hidden">
              <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; background:#2B2620; color:#EAE3D5; padding:8px 12px; font-family:var(--mono); font-size:11px;">
                <span style="opacity:.6;">{article.arxiv_id ? `arXiv:${article.arxiv_id}` : "Source paper"}</span>
                {article.source_url && <a href={article.source_url} target="_blank" rel="noopener noreferrer" style="color:#F0A878; text-decoration:none;">Open on arXiv ↗</a>}
              </div>
              <iframe src={pdfEmbed} title="Source PDF" style="width:100%; height:720px; border:1px solid rgba(33,28,22,.16); border-top:none; background:#fff;"></iframe>
            </div>
          )}

          <!-- QUIZ -->
          <div id="quizCard" style="margin-top:30px; background:var(--card); border:1px solid rgba(33,28,22,.13); padding:26px 28px; position:relative;">
            <div class="section-label">Test your understanding</div>
            <p style="margin:0 0 18px; font-size:14px; color:var(--ink-soft); font-style:italic;">Pass all three to earn the “read &amp; understood” stamp (+10 pts).</p>
            <div id="quizQuestions"></div>
            <div class="row center gap-12" style="margin-top:6px;">
              <button id="quizCheck" class="btn-ink" type="button">Check answers</button>
              <span id="quizMsg" style="font-family:var(--mono); font-size:12px; color:var(--ink-soft);"></span>
            </div>
            <div id="quizStamp" class="hidden" style="position:absolute; top:18px; right:20px; transform:rotate(-9deg); border:3px double var(--ok); color:var(--ok); padding:8px 12px; text-align:center; font-family:var(--mono); background:rgba(252,250,244,.7);">
              <div style="font-size:13px; font-weight:700; letter-spacing:.12em;">UNDERSTOOD</div>
              <div style="font-size:10px; letter-spacing:.1em;">+10 PTS</div>
            </div>
          </div>
        </div>

        <!-- RIGHT MARGIN: member notes + leaderboard -->
        <div class="lmside right" style="padding-top:30px;">
          <div>
            <div class="row gap-8" style="justify-content:space-between; align-items:center; margin-bottom:12px;">
              <span style="font-family:var(--mono); font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:var(--ink-faintest);">Member notes</span>
              {!me && <a href="/login" style="font-family:var(--mono); font-size:10px; letter-spacing:.06em; text-transform:uppercase; color:var(--accent); border:1px solid rgba(194,65,12,.4); padding:4px 9px; text-decoration:none;">Sign in ↗</a>}
            </div>
            <div class="mn-card" data-reveal style="margin-bottom:12px;">
              <div class="row gap-8" style="align-items:center; margin-bottom:6px;">
                <span class="mn-avatar" style="width:22px; height:22px; font-size:9px; background:var(--accent);">{(article.reviewer_name ?? "MT").split(" ").map((w) => w[0]).join("").slice(0, 2)}</span>
                <span style="font-family:var(--mono); font-size:10px; color:var(--ink-soft); flex:1;">{article.reviewer_name ?? "Marginalia team"}</span>
                <span style="font-family:var(--mono); font-size:8px; letter-spacing:.1em; padding:2px 5px; color:var(--accent); border:1px solid rgba(194,65,12,.4);">TEAM</span>
              </div>
              <div class="mn-body">We read the full paper and rewrote it in plain language. Leave your own note below.</div>
            </div>

            <div id="annList">
              {annotations.map((a) => (
                <div class="mn-card" style="margin-bottom:12px;">
                  <div class="row gap-8" style="align-items:center; margin-bottom:6px;">
                    <span class="mn-avatar" style="width:22px; height:22px; font-size:9px;">{initialsOf(a.author_name)}</span>
                    <span style="font-family:var(--mono); font-size:10px; color:var(--ink-soft); flex:1;">{a.author_name}</span>
                    <span style="font-family:var(--mono); font-size:8px; letter-spacing:.1em; padding:2px 5px; color:var(--accent-2); border:1px solid rgba(30,58,95,.4);">MEMBER</span>
                  </div>
                  <div class="mn-body">{a.body}</div>
                </div>
              ))}
            </div>

            {me ? (
              <div class="mn-card" style="margin-bottom:12px;">
                <div class="mn-label">Add a note</div>
                <textarea id="annInput" class="paper-textarea" rows="3" maxlength="280" placeholder="Explain a bit in plain words…" style="margin-top:6px;"></textarea>
                <div class="row gap-8" style="margin-top:8px; align-items:center; justify-content:space-between;">
                  <span id="annCount" style="font-family:var(--mono); font-size:9px; color:var(--ink-faint);">0/280</span>
                  <button id="annSubmit" class="btn-ink" type="button" style="padding:7px 14px;">Post note</button>
                </div>
                <span id="annMsg" style="display:block; margin-top:6px; font-family:var(--mono); font-size:10px; color:var(--ink-soft);"></span>
              </div>
            ) : null}
          </div>

          <!-- chapter leaderboard: honest empty state until chapters exist -->
          <div class="mn-card" data-reveal style="rotate:.5deg;">
            <div class="mn-label">Leaderboard · this week</div>
            <p class="mn-body" style="margin:6px 0 10px;">Pass quizzes and leave notes to climb your chapter's board. No chapters are running yet, so this one is wide open.</p>
            <a href="/chapters/start" class="text-link">Start a chapter to compete →</a>
          </div>
        </div>
      </section>

      {related.length > 0 && (
        <div style="max-width:680px; margin:10px auto 0;">
          <div class="section-label">Related reads</div>
          {related.map((a) => (
            <a class="note-row" href={`/article/${a.slug}`}>
              <span class="nr-main"><span class="title">{a.plain_title}</span><br /><span class="meta">{a.directions?.[0]?.name ?? a.difficulty}</span></span>
              <span class="arr">→</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>

  <div id="toast" class="hidden" style="position:fixed; bottom:24px; left:50%; transform:translateX(-50%); z-index:80; background:var(--ink); color:var(--paper); padding:11px 20px; font-family:var(--mono); font-size:12px;"></div>

  <script define:vars={{ articleSlug: article.slug, articleId: article.id, loggedIn: !!me }}>
    // ----- mode toggle -----
    const exPane = document.getElementById("explainerPane");
    const srcPane = document.getElementById("sourcePane");
    const exBtn = document.getElementById("modeExplainer");
    const srcBtn = document.getElementById("modeSource");
    function setMode(src) {
      exPane.classList.toggle("hidden", src);
      srcPane.classList.toggle("hidden", !src);
      exBtn.className = src ? "btn-outline" : "btn-ink";
      srcBtn.className = src ? "btn-ink" : "btn-outline";
    }
    exBtn?.addEventListener("click", () => setMode(false));
    srcBtn?.addEventListener("click", () => setMode(true));

    // ----- explain simpler -----
    const eBtn = document.getElementById("explainBtn");
    const eIn = document.getElementById("explainInput");
    const eRes = document.getElementById("explainResult");
    eBtn?.addEventListener("click", async () => {
      const sentence = eIn.value.trim();
      if (!sentence) return;
      eBtn.disabled = true; eBtn.textContent = "Thinking…";
      eRes.classList.remove("hidden"); eRes.textContent = "";
      try {
        const r = await fetch("/api/explain-simpler", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ sentence, slug: articleSlug }) });
        const d = await r.json();
        eRes.textContent = d.explanation || d.error || "Couldn't explain that right now.";
      } catch { eRes.textContent = "The assistant is unavailable right now."; }
      finally { eBtn.disabled = false; eBtn.textContent = "Explain it simpler"; }
    });

    // ----- quiz (article-specific, generated by AI + cached) -----
    const toast = (m) => { const t = document.getElementById("toast"); t.textContent = m; t.classList.remove("hidden"); setTimeout(() => t.classList.add("hidden"), 2200); };
    const qWrap = document.getElementById("quizQuestions");
    const quizCheckBtn = document.getElementById("quizCheck");
    const quizMsg = document.getElementById("quizMsg");
    let QUESTIONS = [];
    const sel = {};
    function renderQuiz() {
      qWrap.innerHTML = "";
      QUESTIONS.forEach((q, qi) => {
        const block = document.createElement("div");
        block.style.marginBottom = "18px";
        block.setAttribute("data-qi", qi);
        const qt = document.createElement("div");
        qt.style.cssText = "font-size:17px; line-height:1.4; margin-bottom:9px;";
        const num = document.createElement("b");
        num.style.cssText = "color:#C2410C; font-family:var(--mono); font-size:13px;";
        num.textContent = (qi + 1) + ". ";
        qt.appendChild(num);
        qt.appendChild(document.createTextNode(q.question));
        block.appendChild(qt);
        (q.options || []).forEach((label, oi) => {
          const b = document.createElement("button");
          b.type = "button";
          b.textContent = label;
          b.style.cssText = "display:block; text-align:left; width:100%; padding:9px 13px; margin-bottom:7px; font-family:var(--serif); font-size:15px; cursor:pointer; background:#FCFAF4; border:1px solid rgba(33,28,22,.18); color:#211C16;";
          b.addEventListener("click", () => {
            sel[qi] = oi;
            [...block.querySelectorAll("button")].forEach((x) => { x.style.borderColor = "rgba(33,28,22,.18)"; x.style.background = "#FCFAF4"; });
            b.style.borderColor = "rgba(33,28,22,.5)"; b.style.background = "rgba(33,28,22,.05)";
          });
          block.appendChild(b);
        });
        const exp = document.createElement("div");
        exp.className = "q-exp hidden";
        exp.style.cssText = "font-family:var(--mono); font-size:11px; line-height:1.5; margin-top:2px; color:var(--ink-soft);";
        block.appendChild(exp);
        qWrap.appendChild(block);
      });
    }
    async function loadQuiz() {
      qWrap.innerHTML = '<div style="font-family:var(--mono); font-size:12px; color:#8a8073;">Building a quiz about this paper…</div>';
      try {
        const r = await fetch(`/api/articles/${articleId}/quiz`);
        const d = await r.json();
        if (r.ok && Array.isArray(d.questions) && d.questions.length) {
          QUESTIONS = d.questions; renderQuiz();
        } else {
          qWrap.innerHTML = '<div style="font-family:var(--mono); font-size:12px; color:#8a8073;">' + (d.error || "Quiz unavailable right now.") + '</div>';
          if (quizCheckBtn) quizCheckBtn.setAttribute("disabled", "true");
        }
      } catch {
        qWrap.innerHTML = '<div style="font-family:var(--mono); font-size:12px; color:#8a8073;">Quiz unavailable right now.</div>';
        if (quizCheckBtn) quizCheckBtn.setAttribute("disabled", "true");
      }
    }
    loadQuiz();
    quizCheckBtn?.addEventListener("click", () => {
      if (!QUESTIONS.length) return;
      if (QUESTIONS.some((q, qi) => sel[qi] === undefined)) { toast("Answer every question first"); return; }
      let correct = 0;
      QUESTIONS.forEach((q, qi) => {
        const block = qWrap.querySelector('[data-qi="' + qi + '"]');
        const btns = block ? [...block.querySelectorAll("button")] : [];
        btns.forEach((b, oi) => {
          if (oi === q.correct_index) { b.style.borderColor = "#2e6b36"; b.style.background = "rgba(46,107,54,.1)"; }
          else if (oi === sel[qi]) { b.style.borderColor = "#b91c1c"; b.style.background = "rgba(185,28,28,.08)"; }
        });
        const exp = block ? block.querySelector(".q-exp") : null;
        if (exp && q.explanation) { exp.textContent = (sel[qi] === q.correct_index ? "Correct. " : "Answer: ") + q.explanation; exp.classList.remove("hidden"); }
        if (sel[qi] === q.correct_index) correct++;
      });
      if (correct === QUESTIONS.length) {
        quizMsg.textContent = "Nailed it, stamp earned.";
        document.getElementById("quizStamp").classList.remove("hidden");
        try { localStorage.setItem("mg.stamp." + articleSlug, "1"); } catch {}
        toast("+10, you understood this one");
      } else {
        quizMsg.textContent = correct + "/" + QUESTIONS.length + " correct. Fix the reds and try again.";
      }
    });

    // ----- chapter leaderboard ----- (real boards arrive with chapters; no fake data)

    // ----- annotations (leave a note in the margin) -----
    const annInput = document.getElementById("annInput");
    const annSubmit = document.getElementById("annSubmit");
    const annMsg = document.getElementById("annMsg");
    const annCount = document.getElementById("annCount");
    const annList = document.getElementById("annList");
    annInput?.addEventListener("input", () => { if (annCount) annCount.textContent = annInput.value.length + "/280"; });
    annSubmit?.addEventListener("click", async () => {
      const body = (annInput && annInput.value ? annInput.value : "").trim();
      if (body.length < 3) { if (annMsg) annMsg.textContent = "Write a little more."; return; }
      annSubmit.setAttribute("disabled", "true"); if (annMsg) annMsg.textContent = "Posting…";
      try {
        const r = await fetch("/api/annotations", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ slug: articleSlug, body }) });
        const d = await r.json();
        if (r.ok && d.annotation) {
          const a = d.annotation;
          const ini = String(a.author_name || "Me").split(/\s+/).map((w) => w[0]).filter(Boolean).slice(0, 2).join("").toUpperCase();
          const card = document.createElement("div");
          card.className = "mn-card"; card.style.marginBottom = "12px";
          const head = document.createElement("div");
          head.className = "row gap-8"; head.style.cssText = "align-items:center; margin-bottom:6px;";
          const av = document.createElement("span");
          av.className = "mn-avatar"; av.style.cssText = "width:22px; height:22px; font-size:9px;"; av.textContent = ini;
          const nm = document.createElement("span");
          nm.style.cssText = "font-family:var(--mono); font-size:10px; color:var(--ink-soft); flex:1;"; nm.textContent = a.author_name;
          const tag = document.createElement("span");
          tag.style.cssText = "font-family:var(--mono); font-size:8px; letter-spacing:.1em; padding:2px 5px; color:var(--accent-2); border:1px solid rgba(30,58,95,.4);"; tag.textContent = "MEMBER";
          head.appendChild(av); head.appendChild(nm); head.appendChild(tag);
          const bodyEl = document.createElement("div");
          bodyEl.className = "mn-body"; bodyEl.textContent = a.body;
          card.appendChild(head); card.appendChild(bodyEl);
          if (annList) annList.insertBefore(card, annList.firstChild);
          annInput.value = ""; if (annCount) annCount.textContent = "0/280";
          if (annMsg) annMsg.textContent = "Posted. Thanks for the note.";
          toast("Note added to the margin");
        } else {
          if (annMsg) annMsg.textContent = d.error || "Could not post that.";
        }
      } catch { if (annMsg) annMsg.textContent = "Network error, try again."; }
      finally { annSubmit.removeAttribute("disabled"); }
    });
  </script>

  {/* Inline glossary annotations: highlight key terms, explain them on hover/tap. */}
  <script define:vars={{ glossTerms: glossary.map((g) => ({ t: g.term, d: g.definition })) }}>
    (() => {
      if (!Array.isArray(glossTerms) || !glossTerms.length) return;
      const terms = glossTerms.slice().sort((a, b) => b.t.length - a.t.length);
      const defByLower = new Map(terms.map((x) => [x.t.toLowerCase(), x.d]));
      const used = new Set();
      const esc = (s) => s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
      const pattern = new RegExp("\\b(" + terms.map((x) => esc(x.t)).join("|") + ")\\b", "i");
      const roots = document.querySelectorAll("#explainerPane .read");

      roots.forEach((root) => {
        // Pass 1: key terms the writer already bolded.
        root.querySelectorAll("strong").forEach((el) => {
          const key = (el.textContent || "").trim().toLowerCase();
          const def = defByLower.get(key);
          if (def && !used.has(key)) {
            used.add(key);
            el.classList.add("gloss");
            el.tabIndex = 0;
            el.setAttribute("data-term", el.textContent.trim());
            el.setAttribute("data-def", def);
          }
        });
        // Pass 2: first plain-text mention of any other term.
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
          acceptNode(node) {
            if (!node.nodeValue || !node.nodeValue.trim()) return NodeFilter.FILTER_REJECT;
            const p = node.parentElement;
            if (!p || p.closest("a, code, mark, .gloss, strong")) return NodeFilter.FILTER_REJECT;
            return NodeFilter.FILTER_ACCEPT;
          },
        });
        const nodes = [];
        let node;
        while ((node = walker.nextNode())) nodes.push(node);
        nodes.forEach((tn) => {
          const text = tn.nodeValue;
          const m = pattern.exec(text);
          if (!m) return;
          const term = m[1];
          const lower = term.toLowerCase();
          if (used.has(lower)) return;
          const def = defByLower.get(lower);
          if (!def) return;
          used.add(lower);
          const mark = document.createElement("mark");
          mark.className = "gloss";
          mark.tabIndex = 0;
          mark.setAttribute("data-term", term);
          mark.setAttribute("data-def", def);
          mark.textContent = term;
          const frag = document.createDocumentFragment();
          const before = text.slice(0, m.index);
          const after = text.slice(m.index + term.length);
          if (before) frag.appendChild(document.createTextNode(before));
          frag.appendChild(mark);
          if (after) frag.appendChild(document.createTextNode(after));
          tn.parentNode.replaceChild(frag, tn);
        });
      });

      const marks = document.querySelectorAll(".gloss");
      if (!marks.length) return;
      const pop = document.createElement("div");
      pop.className = "gloss-pop hidden";
      document.body.appendChild(pop);
      let hideT;
      const show = (el) => {
        clearTimeout(hideT);
        pop.innerHTML = "";
        const label = document.createElement("div");
        label.className = "gloss-pop-term";
        label.textContent = el.getAttribute("data-term") || "";
        const body = document.createElement("div");
        body.className = "gloss-pop-def";
        body.textContent = el.getAttribute("data-def") || "";
        pop.appendChild(label);
        pop.appendChild(body);
        pop.classList.remove("hidden");
        const r = el.getBoundingClientRect();
        const pw = pop.offsetWidth;
        let left = window.scrollX + r.left;
        left = Math.min(left, window.scrollX + document.documentElement.clientWidth - pw - 12);
        left = Math.max(12, left);
        pop.style.left = left + "px";
        pop.style.top = window.scrollY + r.bottom + 8 + "px";
      };
      const hide = () => { hideT = setTimeout(() => pop.classList.add("hidden"), 140); };
      marks.forEach((el) => {
        el.addEventListener("mouseenter", () => show(el));
        el.addEventListener("mouseleave", hide);
        el.addEventListener("focus", () => show(el));
        el.addEventListener("blur", hide);
        el.addEventListener("click", (e) => { e.stopPropagation(); show(el); });
      });
      pop.addEventListener("mouseenter", () => clearTimeout(hideT));
      pop.addEventListener("mouseleave", hide);
      document.addEventListener("click", (e) => {
        if (!(e.target instanceof Element) || !e.target.closest(".gloss")) pop.classList.add("hidden");
      });
    })();
  </script>
</BaseLayout>
