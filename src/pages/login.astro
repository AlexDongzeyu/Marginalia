---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
---
<BaseLayout title="Sign in — Marginalia" bodyClass="page-login">
  <Sheet>
    <Masthead title="Welcome back" tagline="Sign in to your reading room." top="Members' entrance" compact={true} />
    <div style="max-width:440px; margin:0 auto;">
      <form id="loginForm" class="stack">
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" class="paper-input" required placeholder="you@school.edu" autocomplete="email" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" class="paper-input" required placeholder="••••••••" autocomplete="current-password" />
        </div>
        <button type="submit" class="btn-ink" style="justify-content:center;">Sign in</button>
        <p id="loginStatus" style="font-family:var(--mono); font-size:11px; color:var(--accent); text-align:center; margin-top:12px;"></p>
      </form>
      <div style="text-align:center; margin-top:22px; padding-top:18px; border-top:1px solid var(--line);">
        <p class="muted" style="margin-bottom:12px;">No account yet?</p>
        <a href="/signup" class="btn-outline">Create account</a>
      </div>
    </div>
  </Sheet>
  <script>
    const form = document.getElementById("loginForm") as HTMLFormElement;
    const status = document.getElementById("loginStatus");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (status) status.textContent = "Signing in…";
      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch("/api/auth/login", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
        const out = await res.json();
        if (res.ok) window.location.href = "/dashboard";
        else if (status) status.textContent = out.error || "Could not sign in.";
      } catch { if (status) status.textContent = "Network error — try again."; }
    });
  </script>
</BaseLayout>
