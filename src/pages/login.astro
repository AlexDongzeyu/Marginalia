---
/**
 * /login — sign-in page. Faithful port of ECHOE's login.html layout
 * (page-container + page-header + form) in the Marginalia context.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Login — Marginalia" bodyClass="page-login">
  <div class="container">
    <div class="auth-wrap">
      <div class="page-container">
        <div class="page-header">
          <h1>Welcome Back</h1>
          <p>Sign in to your Marginalia account</p>
        </div>

        <form id="loginForm" method="post" action="/api/auth/login" class="auth-form">
          <div class="field">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="you@email.com" autocomplete="email" />
          </div>

          <div class="field">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Enter your password" autocomplete="current-password" />
          </div>

          <button type="submit" class="btn btn-primary auth-submit">
            <span aria-hidden="true">&#128274;</span> Sign In
          </button>
          <p id="loginStatus" class="auth-status"></p>
        </form>

        <div class="auth-divider">
          <p>Don't have an account yet?</p>
          <a href="/signup" class="btn btn-secondary">
            <span aria-hidden="true">&#10133;</span> Create Account
          </a>
        </div>
      </div>

      <div class="page-container auth-aside">
        <h3>Want to help build Marginalia?</h3>
        <p>Join the community — write explainers, curate the research map, or start a chapter at your school.</p>
        <a href="/join" class="btn btn-secondary">Learn about joining</a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById("loginForm") as HTMLFormElement;
    const status = document.getElementById("loginStatus");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (status) status.textContent = "Signing in…";
      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch("/api/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        const out = await res.json();
        if (res.ok) {
          window.location.href = "/dashboard";
        } else if (status) {
          status.textContent = out.error || "Could not sign in.";
        }
      } catch {
        if (status) status.textContent = "Network error — please try again.";
      }
    });
  </script>
</BaseLayout>

<style>
  .auth-wrap { max-width: 520px; margin: 0 auto; }
  .auth-form { margin-top: 10px; }
  .field { margin-bottom: 22px; }
  .field label {
    display: block;
    margin-bottom: 8px;
    font-weight: 700;
    color: var(--deep-indigo);
    font-size: 1.05rem;
  }
  .field input {
    width: 100%;
    padding: 14px;
    border: 2px solid rgba(42, 61, 102, 0.2);
    border-radius: 10px;
    font-size: 1rem;
    font-family: "Nunito", sans-serif;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .field input:focus {
    outline: none;
    border-color: var(--soft-yellow);
    box-shadow: 0 0 0 3px rgba(248, 210, 156, 0.3);
  }
  .auth-submit { width: 100%; justify-content: center; padding: 14px; }
  .auth-status { margin-top: 12px; font-weight: 700; color: #b3402f; text-align: center; }
  .auth-divider {
    text-align: center;
    padding: 24px 0 4px;
    margin-top: 18px;
    border-top: 1px solid rgba(42, 61, 102, 0.15);
  }
  .auth-divider p { margin-bottom: 14px; color: var(--deep-indigo); }
  .auth-aside { margin-top: 26px; text-align: center; }
  .auth-aside h3 { margin-bottom: 12px; }
  .auth-aside p { margin-bottom: 16px; }
</style>
