---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";

const projects = [
  { title: "Plain-language paper explainers", blurb: "The morning pipeline: arXiv → Workers AI → human review.", tags: ["NLP", "Pipeline", "Open"], status: "Live" },
  { title: "Research direction map", blurb: "An editorial, clickable map of AI research directions.", tags: ["Visualization", "Education"], status: "Live" },
  { title: "Living-margin reading mode", blurb: "Notes, definitions, and jokes in the margins; Focus mode for clean reading.", tags: ["Accessibility", "Design"], status: "Live" },
];
---
<BaseLayout title="Projects · Marginalia" bodyClass="page-projects">
  <Sheet>
    <Masthead title="Projects" tagline="Things we build in the open." top="The workshop" compact={true} />
    <div style="max-width:680px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:14px;">
      {projects.map((p) => (
        <div class="torn-card" data-reveal>
          <span class="tag tag-good">{p.status}</span>
          <h3 style="margin-top:8px;">{p.title}</h3>
          <p style="margin-bottom:8px;">{p.blurb}</p>
          <div class="row wrap gap-8">{p.tags.map((t) => <span class="tag">{t}</span>)}</div>
        </div>
      ))}
    </div>
    <p class="text-center muted mt-24">Want yours here? <a href="/join">Join us</a>.</p>
  </Sheet>
</BaseLayout>
