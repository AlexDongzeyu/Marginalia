---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import { listDraftArticles } from "../lib/db";

const { env } = Astro.locals.runtime;
const drafts = await listDraftArticles(env.DB);
---
<BaseLayout title="Review queue · Marginalia" bodyClass="page-admin" hideComfort={true}>
  <Sheet>
    <Masthead title="Review queue" tagline="Nothing publishes without a human." top="Editorial" compact={true} />
    <div style="max-width:720px; margin:0 auto;">
      <div class="mn-card" style="max-width:none; display:flex; flex-wrap:wrap; align-items:center; gap:10px; margin-bottom:18px;">
        <input id="adminToken" type="password" placeholder="Paste ADMIN_TOKEN" class="paper-input" style="width:auto; flex:1 1 180px;" autocomplete="off" />
        <input id="reviewerName" type="text" placeholder="Your name (byline)" class="paper-input" style="width:auto; flex:1 1 140px;" />
        <button id="runIngest" class="btn-outline" type="button">Run ingest now</button>
        <span id="ingestStatus" class="muted" style="font-family:var(--mono); font-size:11px;"></span>
      </div>

      {drafts.length === 0 ? (
        <div class="scrap"><h2>No drafts waiting</h2><p class="hook">Run the ingest to pull and explain fresh papers.</p></div>
      ) : (
        drafts.map((d) => (
          <div class="mn-card draft-card" data-id={d.id} style="max-width:none; margin-bottom:16px;">
            <div class="row wrap gap-8" style="justify-content:space-between;">
              <span class="tag">{d.status}</span>
              <span class="muted" style="font-family:var(--mono); font-size:10px;">arXiv: {d.arxiv_id ?? "n/a"} · {d.ai_model}</span>
            </div>
            <label class="field" style="margin:10px 0 0;"><span style="font-family:var(--mono); font-size:9px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-faint);">Plain title</span><input class="paper-input edit-plain_title" value={d.plain_title} /></label>
            <p class="muted" style="font-size:12px; margin:8px 0;">orig: <em>{d.original_title}</em></p>
            <label class="field" style="margin:0;"><span style="font-family:var(--mono); font-size:9px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-faint);">Hook</span><textarea class="paper-textarea edit-hook" rows="2">{d.hook}</textarea></label>
            <label class="field" style="margin:8px 0 0;"><span style="font-family:var(--mono); font-size:9px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-faint);">What's going on</span><textarea class="paper-textarea edit-whats_going_on" rows="6">{d.whats_going_on}</textarea></label>
            <label class="field" style="margin:8px 0 0;"><span style="font-family:var(--mono); font-size:9px; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-faint);">Why it matters</span><textarea class="paper-textarea edit-why_it_matters" rows="3">{d.why_it_matters}</textarea></label>
            <div class="row wrap gap-8" style="margin-top:10px;">
              <span class="tag tag-good">{d.difficulty}</span>
              {d.is_ai4good === 1 && <span class="tag tag-good">AI for Good</span>}
              {d.source_url && <a class="text-link" href={d.source_url} target="_blank" rel="noopener noreferrer">Check source ↗</a>}
            </div>
            <div class="row wrap gap-8" style="margin-top:14px;">
              <button class="btn-outline act-save" type="button">Save edits</button>
              <button class="btn-ink act-publish" type="button">Publish</button>
              <button class="btn-outline act-aotd" type="button">Publish as Today</button>
              <button class="btn-outline act-reject" type="button" style="margin-left:auto;">Reject</button>
            </div>
            <span class="row-status muted" style="display:block; margin-top:8px; font-family:var(--mono); font-size:11px;"></span>
          </div>
        ))
      )}
    </div>
  </Sheet>
  <script>
    const tokenEl = document.getElementById("adminToken") as HTMLInputElement;
    const reviewerEl = document.getElementById("reviewerName") as HTMLInputElement;
    function authHeaders() { return { "Content-Type": "application/json", Authorization: `Bearer ${tokenEl.value.trim()}` }; }
    async function review(id: string, payload: Record<string, unknown>, statusEl: Element | null) {
      if (!tokenEl.value.trim()) { if (statusEl) statusEl.textContent = "Enter the admin token first."; return; }
      if (statusEl) statusEl.textContent = "Working…";
      try {
        const res = await fetch(`/api/articles/${id}/review`, { method: "POST", headers: authHeaders(), body: JSON.stringify({ ...payload, reviewer: reviewerEl.value.trim() || "Editorial" }) });
        const data = await res.json();
        if (statusEl) statusEl.textContent = res.ok ? `${data.status}` : `${data.error}`;
        if (res.ok && (payload.action === "publish" || payload.action === "reject" || payload.action === "set-aotd")) {
          const card = document.querySelector(`.draft-card[data-id="${id}"]`); if (card) (card as HTMLElement).style.opacity = "0.5";
        }
      } catch { if (statusEl) statusEl.textContent = "Network error."; }
    }
    function fieldValues(card: Element) {
      const get = (cls: string) => (card.querySelector(cls) as HTMLInputElement | HTMLTextAreaElement)?.value ?? "";
      return { plain_title: get(".edit-plain_title"), hook: get(".edit-hook"), whats_going_on: get(".edit-whats_going_on"), why_it_matters: get(".edit-why_it_matters") };
    }
    document.querySelectorAll(".draft-card").forEach((card) => {
      const id = (card as HTMLElement).dataset.id!;
      const statusEl = card.querySelector(".row-status");
      card.querySelector(".act-save")?.addEventListener("click", () => review(id, { action: "update", ...fieldValues(card) }, statusEl));
      card.querySelector(".act-publish")?.addEventListener("click", async () => { await review(id, { action: "update", ...fieldValues(card) }, statusEl); await review(id, { action: "publish" }, statusEl); });
      card.querySelector(".act-aotd")?.addEventListener("click", async () => { await review(id, { action: "update", ...fieldValues(card) }, statusEl); await review(id, { action: "set-aotd" }, statusEl); });
      card.querySelector(".act-reject")?.addEventListener("click", () => review(id, { action: "reject" }, statusEl));
    });
    document.getElementById("runIngest")?.addEventListener("click", async () => {
      const statusEl = document.getElementById("ingestStatus");
      if (!tokenEl.value.trim()) { if (statusEl) statusEl.textContent = "Enter the admin token first."; return; }
      if (statusEl) statusEl.textContent = "Fetching + explaining…";
      try {
        const res = await fetch(`/api/cron/ingest`, { method: "POST", headers: authHeaders() });
        const data = await res.json();
        if (statusEl) statusEl.textContent = res.ok ? `Drafted ${data.drafted} (fetched ${data.fetched}). Reload to see them.` : `${data.error}`;
      } catch { if (statusEl) statusEl.textContent = "Network error."; }
    });
  </script>
</BaseLayout>
