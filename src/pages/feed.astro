---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { listPublishedArticles, getAllDirections } from "../lib/db";

const { env } = Astro.locals.runtime;
const url = Astro.url;
const direction = url.searchParams.get("direction") ?? "";
const difficulty = url.searchParams.get("difficulty") ?? "";
const ai4good = url.searchParams.get("ai4good") === "1";
const search = url.searchParams.get("q") ?? "";

const [articles, directions] = await Promise.all([
  listPublishedArticles(env.DB, {
    direction: direction || undefined,
    difficulty: difficulty || undefined,
    ai4good: ai4good || undefined,
    search: search || undefined,
    limit: 60,
  }),
  getAllDirections(env.DB),
]);
const childDirections = directions.filter((d) => d.parent_id);
const difficulties = ["Beginner", "Intermediate", "Advanced"];
---
<BaseLayout title="The feed — Marginalia" bodyClass="page-feed">
  <Sheet>
    <Masthead title="The Feed" tagline="Every paper we've explained, in order." top="The archive" compact={true} />

    <div style="max-width:680px; margin:0 auto;">
      <form method="get" style="display:flex; flex-wrap:wrap; gap:8px; align-items:center; margin-bottom:18px; background:var(--card); border:1px solid var(--line); padding:14px;">
        <input type="search" name="q" value={search} placeholder="Search titles & summaries…" class="paper-input" style="flex:1 1 220px;" aria-label="Search" />
        <select name="direction" class="paper-select" style="width:auto;" aria-label="Direction">
          <option value="">All directions</option>
          {childDirections.map((d) => <option value={d.slug} selected={d.slug === direction}>{d.name}</option>)}
        </select>
        <select name="difficulty" class="paper-select" style="width:auto;" aria-label="Level">
          <option value="">Any level</option>
          {difficulties.map((d) => <option value={d} selected={d === difficulty}>{d}</option>)}
        </select>
        <label style="display:inline-flex; align-items:center; gap:6px; font-family:var(--mono); font-size:11px; color:var(--ink);"><input type="checkbox" name="ai4good" value="1" checked={ai4good} /> AI for Good</label>
        <button type="submit" class="btn-ink">Filter</button>
        {(direction || difficulty || ai4good || search) && <a href="/feed" class="text-link">Clear</a>}
      </form>

      <p style="font-family:var(--mono); font-size:11px; color:var(--ink-faint); margin-bottom:6px;">{articles.length} {articles.length === 1 ? "paper" : "papers"}</p>

      {articles.length > 0 ? (
        articles.map((a) => <ArticleCard article={a} />)
      ) : (
        <div class="scrap"><h2>No papers match those filters yet</h2><p class="hook">Try clearing filters, or check back after the next morning run.</p></div>
      )}
    </div>
  </Sheet>
</BaseLayout>
