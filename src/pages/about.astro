---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import MarginRow from "../components/MarginRow.astro";
import MarginNote from "../components/MarginNote.astro";
import TornDivider from "../components/TornDivider.astro";
---
<BaseLayout title="About · Marginalia" bodyClass="page-about">
  <Sheet>
    <Masthead title="About" tagline="Why a few students read AI papers so you don't have to." top="The masthead" compact={true} />

    <MarginRow>
      <Fragment slot="left">
        <MarginNote variant="hand" anchor="who">yes, really. a teenager. with a red pen. <span class="mn-arrow">↘</span></MarginNote>
      </Fragment>
      <div class="read">
        <div class="section-label">Our mission</div>
        <p>AI research moves fast and is written for experts. Marginalia is a free,
          student-run guide that explains new and notable AI work in plain language,
          maps the field so newcomers can explore it, and, once you understand
          something, lets <span class="anchor" data-anchor="who">you annotate it</span> for the next person.</p>
        <p>The name is a nod to <span class="anchor" data-anchor="def">marginalia</span>: the notes people scribble in
          the margins to make a difficult text their own. That's what we do, in
          public, for AI.</p>
      </div>
      <Fragment slot="right">
        <MarginNote variant="def" anchor="def" taped={true} tilt="l"><b>marginalia</b> (n.), notes in the margins of a book. here, the whole point.</MarginNote>
      </Fragment>
    </MarginRow>

    <TornDivider variant="a" />

    <MarginRow>
      <div class="read">
        <div class="section-label">How we work</div>
        <p>Each morning a pipeline pulls fresh papers from arXiv, drops anything
          we've covered, and drafts a plain-language explainer with Cloudflare's
          Workers AI. Then a person reviews every draft against the source before
          it publishes. The AI does the finding and drafting; humans own the
          quality bar.</p>
      </div>
      <Fragment slot="right">
        <MarginNote variant="hand">no unreviewed robot text goes live. ever. <span class="mn-arrow">←</span></MarginNote>
      </Fragment>
    </MarginRow>

    <TornDivider variant="b" />

    <section id="integrity" style="max-width:620px; margin:0 auto;">
      <div class="section-label">Integrity &amp; sources</div>
      <div class="read">
        <ul>
          <li><strong>Original summaries only.</strong> We never republish a paper's abstract verbatim.</li>
          <li><strong>We credit and link everything</strong>, authors, the arXiv page, the PDF.</li>
          <li><strong>Transparency labels.</strong> AI involvement is always marked.</li>
          <li><strong>Human review before publish.</strong> The editorial queue is our anti-hallucination check.</li>
          <li><strong>The scrutiny test.</strong> Everything here should survive a researcher clicking through.</li>
        </ul>
      </div>
    </section>

    <section style="max-width:620px; margin:24px auto 0;">
      <div class="section-label">The team</div>
      <p class="read">Marginalia is built by students. Want to write explainers, build
        features, or start a chapter? <a href="/join">Come say hi.</a></p>
    </section>
  </Sheet>
</BaseLayout>
