---
/**
 * /about — mission, how we work, integrity & sources, venue policy.
 * The integrity section (#integrity) is linked from the footer and is central
 * to the project's credibility.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About — Marginalia" bodyClass="page-about">
  <div class="container" style="max-width:860px;">
    <div class="page-header">
      <p class="tagline">Why we built this</p>
      <h1>About Marginalia</h1>
    </div>

    <div class="content-section">
      <h2>Our mission</h2>
      <p class="prose">
        AI research moves fast and is written for experts. Marginalia is a free,
        student-run guide that explains new and notable AI work in plain language,
        maps the field so newcomers can explore it, and teaches the skills to go
        deeper — all oriented around <strong>AI for good</strong>.
      </p>
      <p class="prose">
        The name is a nod to marginalia: the notes people write in the margins to
        make a difficult text their own. That's what we do, in public, for AI.
      </p>
    </div>

    <div class="content-section">
      <h2>How we work</h2>
      <p class="prose">
        Each day an automated pipeline pulls fresh papers from arXiv, drops anything
        we've covered before, and drafts a plain-language explainer using
        Cloudflare's Workers AI. Then a person reviews every draft against the
        source before it publishes. The AI does the heavy lifting of finding and
        drafting; humans own the quality bar.
      </p>
    </div>

    <div class="content-section integrity" id="integrity">
      <h2>Integrity &amp; sources</h2>
      <ul class="prose">
        <li><strong>Original summaries only.</strong> We write our own plain-language explanations and never republish a paper's abstract verbatim.</li>
        <li><strong>We credit and link everything.</strong> Every explainer names the authors and links to the arXiv page and PDF.</li>
        <li><strong>Transparency labels.</strong> AI involvement is always marked: "AI-assisted summary, reviewed by [name]."</li>
        <li><strong>Human review before publish.</strong> The editorial queue is our anti-hallucination check.</li>
        <li><strong>Respect for sources.</strong> We follow arXiv's API etiquette, cache responses, and store only metadata plus our own words.</li>
        <li><strong>The scrutiny test.</strong> Everything here should survive a researcher clicking through to check it.</li>
      </ul>
    </div>

    <div class="content-section">
      <h2>The team</h2>
      <p class="prose">
        Marginalia is built by students. Want to write explainers, build features,
        or start a chapter? <a href="/join">Come say hi.</a>
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .integrity { background: var(--frame-blue); border-color: rgba(122, 174, 182, 0.5); }
</style>
