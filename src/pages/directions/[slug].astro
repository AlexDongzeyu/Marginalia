---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Sheet from "../../components/Sheet.astro";
import Masthead from "../../components/Masthead.astro";
import MarginRow from "../../components/MarginRow.astro";
import MarginNote from "../../components/MarginNote.astro";
import { getDirectionBySlug, listPublishedArticles, getDirectionsWithCounts } from "../../lib/db";

const { slug } = Astro.params;
const { env } = Astro.locals.runtime;
const direction = slug ? await getDirectionBySlug(env.DB, slug) : null;
if (!direction) return new Response(null, { status: 404, statusText: "Not Found" });

const [articles, allDirections] = await Promise.all([
  listPublishedArticles(env.DB, { direction: direction.slug, limit: 50 }),
  getDirectionsWithCounts(env.DB),
]);
const foundational = articles.filter((a) => a.is_foundational === 1);
const latest = articles.filter((a) => a.is_foundational !== 1);
const related = allDirections.filter((d) => d.branch === direction.branch && d.parent_id && d.slug !== direction.slug);
const branchLabel: Record<string, string> = { foundations: "Foundations", methods: "Methods & Models", applied: "AI for Good", society: "Safety & Society" };
---
<BaseLayout title={`${direction.name} — Marginalia`} description={direction.plain_description} bodyClass="page-direction">
  <Sheet>
    <Masthead title={direction.name} tagline={branchLabel[direction.branch]} top="A direction" compact={true} />
    <MarginRow>
      <Fragment slot="left">
        <MarginNote variant="hand">new here? start with the foundational reads. <span class="mn-arrow">↘</span></MarginNote>
      </Fragment>
      <div>
        <p class="read">{direction.plain_description}</p>
        {foundational.length > 0 && (
          <section style="margin-top:24px;">
            <div class="section-label">Start here — foundational reads</div>
            {foundational.map((a) => (
              <a class="note-row" href={`/article/${a.slug}`}><span class="nr-main"><span class="title">{a.plain_title}</span><br /><span class="meta">{a.difficulty}</span></span><span class="arr">→</span></a>
            ))}
          </section>
        )}
        <section style="margin-top:24px;">
          <div class="section-label">Latest in {direction.name}</div>
          {latest.length > 0 ? latest.map((a) => (
            <a class="note-row" href={`/article/${a.slug}`}><span class="nr-main"><span class="title">{a.plain_title}</span><br /><span class="meta">{a.difficulty}</span></span><span class="arr">→</span></a>
          )) : <p class="muted">No new papers tagged here yet — the pipeline will fill this in.</p>}
        </section>
        {related.length > 0 && (
          <section style="margin-top:24px;">
            <div class="section-label">Related directions</div>
            <div class="row wrap gap-8">{related.map((d) => <a class="text-link" href={`/directions/${d.slug}`}>{d.name}</a>)}</div>
          </section>
        )}
      </div>
      <Fragment slot="right" />
    </MarginRow>
  </Sheet>
</BaseLayout>
