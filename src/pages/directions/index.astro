---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Sheet from "../../components/Sheet.astro";
import Masthead from "../../components/Masthead.astro";
import { getDirectionsWithCounts } from "../../lib/db";

const { env } = Astro.locals.runtime;
const directions = await getDirectionsWithCounts(env.DB);
const branches = [
  { key: "foundations", label: "Foundations", blurb: "The core ideas that make modern AI work." },
  { key: "methods", label: "Methods & Models", blurb: "The building blocks researchers combine." },
  { key: "applied", label: "AI for Good", blurb: "Where AI meets real-world problems." },
  { key: "society", label: "Safety & Society", blurb: "Making AI trustworthy and fair." },
] as const;
---
<BaseLayout title="Research directions — Marginalia" bodyClass="page-directions">
  <Sheet>
    <Masthead title="Directions" tagline="The field, organised." top="The index" compact={true} />
    <p class="muted text-center" style="margin-bottom:18px;">Prefer the visual version? <a href="/map">Open the map →</a></p>
    <div style="max-width:680px; margin:0 auto;">
      {branches.map((branch) => {
        const children = directions.filter((d) => d.branch === branch.key && d.parent_id);
        return (
          <section style="margin-bottom:30px;">
            <div class="section-label">{branch.label}</div>
            <p class="muted" style="margin:-6px 0 12px; font-size:14px;">{branch.blurb}</p>
            {children.map((d) => (
              <a class="note-row" href={`/directions/${d.slug}`}>
                <span class="nr-main"><span class="title">{d.name}</span><br /><span class="meta">{d.article_count > 0 ? `${d.article_count} reads` : "coming soon"}</span></span>
                <span class="arr">→</span>
              </a>
            ))}
          </section>
        );
      })}
    </div>
  </Sheet>
</BaseLayout>
