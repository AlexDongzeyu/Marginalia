---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import { getApprovedGlossary } from "../lib/db";

const { env } = Astro.locals.runtime;
const terms = await getApprovedGlossary(env.DB);
---
<BaseLayout title="Glossary — Marginalia" bodyClass="page-glossary">
  <Sheet>
    <Masthead title="Glossary" tagline="Every bit of jargon, in one sentence." top="Definitions" compact={true} />
    <div style="max-width:680px; margin:0 auto;">
      <input type="search" id="glossarySearch" placeholder="Search terms…" class="paper-input" style="margin-bottom:20px;" aria-label="Search glossary" />
      <dl id="glossaryList" style="margin:0;">
        {terms.map((t) => (
          <div class="mn-card glossary-item" data-term={t.term.toLowerCase()} style="max-width:none; margin-bottom:12px;">
            <dt class="mn-label" style="font-size:11px;">{t.term}</dt>
            <dd class="mn-body" style="margin:4px 0 0; font-size:14px;">{t.definition}</dd>
          </div>
        ))}
      </dl>
      {terms.length === 0 && <p class="muted text-center">No terms yet — the pipeline proposes new ones as articles publish.</p>}
    </div>
  </Sheet>
  <script>
    const search = document.getElementById("glossarySearch") as HTMLInputElement | null;
    const items = Array.from(document.querySelectorAll<HTMLElement>(".glossary-item"));
    search?.addEventListener("input", () => {
      const q = search.value.trim().toLowerCase();
      items.forEach((it) => {
        const t = it.dataset.term ?? "";
        const text = it.textContent?.toLowerCase() ?? "";
        it.style.display = !q || t.includes(q) || text.includes(q) ? "" : "none";
      });
    });
  </script>
</BaseLayout>
