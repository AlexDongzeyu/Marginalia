---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import MarginRow from "../components/MarginRow.astro";
import MarginNote from "../components/MarginNote.astro";
import { getArticleOfDay } from "../lib/db";

const { env } = Astro.locals.runtime;
const article = await getArticleOfDay(env.DB);
const today = new Date().toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" });
const diffClass = article?.difficulty === "Beginner" ? "tag-beginner" : article?.difficulty === "Advanced" ? "tag-advanced" : "tag-intermediate";
---
<BaseLayout title="Today · Marginalia" bodyClass="page-today">
  <Sheet>
    <Masthead title="Today's Margin" tagline={today} top="The paper worth understanding" compact={true} />
    <MarginRow>
      <Fragment slot="left">
        <MarginNote variant="hand">fresh every morning before school. <span class="mn-arrow">↘</span></MarginNote>
      </Fragment>
      <div>
        {article ? (
          <div class="scrap">
            <svg class="clip" width="34" height="64" viewBox="0 0 34 64"><path d="M17 8 C9 8 7 14 7 22 L7 46 C7 55 13 58 18 58 C24 58 28 53 28 46 L28 18 C28 13 24 11 21 11 C17 11 14 14 14 19 L14 44" fill="none" stroke="#9aa0a6" stroke-width="3.4" stroke-linecap="round"></path></svg>
            <div class="scrap-tags">
              {article.directions?.[0] && <span class="tag tag-lm">{article.directions[0].name}</span>}
              <span class={`tag ${diffClass}`}>{article.difficulty}</span>
              <span class="tag">{article.read_minutes} min read</span>
            </div>
            <h2>{article.plain_title}</h2>
            <p class="orig">orig. “{article.original_title}”</p>
            <p class="hook">{article.hook}</p>
            <a href={`/article/${article.slug}`} class="more">Read the annotated version →</a>
          </div>
        ) : (
          <div class="scrap"><h2>No pick yet today</h2><p class="hook">The morning pipeline hasn't published yet. Browse <a href="/feed">the feed</a>.</p></div>
        )}
        <div class="cta-row"><a href="/feed" class="btn-outline">Browse all papers</a></div>
      </div>
      <Fragment slot="right">
        {article && (
          <MarginNote variant="why" tilt="r">{article.is_ai4good === 1 ? "real-world stakes, AI pointed at a problem that matters." : "a foundational idea worth getting right."}</MarginNote>
        )}
      </Fragment>
    </MarginRow>
  </Sheet>
</BaseLayout>
