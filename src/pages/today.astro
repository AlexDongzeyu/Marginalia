---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import MarginNote from "../components/MarginNote.astro";
import { getArticleOfDay } from "../lib/db";
import { renderMarkdown } from "../lib/markdown";

const { env } = Astro.locals.runtime;
const article = await getArticleOfDay(env.DB);
const today = new Date().toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" });
const diffClass = article?.difficulty === "Beginner" ? "tag-beginner" : article?.difficulty === "Advanced" ? "tag-advanced" : "tag-intermediate";
const whatsGoingOn = article ? renderMarkdown(article.whats_going_on) : "";
const whyItMatters = article ? renderMarkdown(article.why_it_matters) : "";
const reviewerInitials = article
  ? (article.reviewer_name ?? "Marginalia team")
      .split(/\s+/)
      .map((w) => w[0])
      .filter(Boolean)
      .slice(0, 2)
      .join("")
      .toUpperCase()
  : "";
---
<BaseLayout title="Today · Marginalia" bodyClass="page-today">
  <Sheet>
    <Masthead title="Today's Margin" tagline={today} compact={true} />

    {article ? (
      <Fragment>
        <div style="max-width:640px; margin:0 auto 4px; text-align:center;">
          <div class="row wrap gap-8 center" style="margin-bottom:14px;">
            {article.directions?.[0] && <span class="tag tag-lm">{article.directions[0].name}</span>}
            <span class={`tag ${diffClass}`}>{article.difficulty}</span>
            <span class="tag">{article.read_minutes} min read</span>
            {article.is_ai4good === 1 && <span class="tag tag-good">AI for Good</span>}
          </div>
          <h1 style="font-size:clamp(30px,4.6vw,48px); line-height:1.04; letter-spacing:-0.02em; font-weight:600; margin:0 0 10px;">{article.plain_title}</h1>
          <p style="font-style:italic; color:var(--ink-soft); font-size:15px; margin:0;">orig. “{article.original_title}”{article.authors?.length ? ` · ${article.authors.slice(0, 3).join(", ")}` : ""}</p>
        </div>

        <section class="lmrow" style="--read-w:600px; align-items:start;">
          <div class="lmside left" style="padding-top:40px;">
            <MarginNote variant="hand">today's one paper. read it properly, not just the headline. <span class="mn-arrow">↘</span></MarginNote>
            <MarginNote variant="def" taped tilt="l" label="Heads up">every bold word has a plain-English note right next to it. no jargon left behind.</MarginNote>
          </div>

          <div class="lmcenter">
            <p class="pullquote">{article.hook}</p>
            <div class="section-label">What's going on</div>
            <div class="read drop-cap"><Fragment set:html={whatsGoingOn} /></div>
            <div class="section-label" style="margin-top:26px;">Why it matters</div>
            <div class="read"><Fragment set:html={whyItMatters} /></div>
            <div class="cta-row">
              <a href={`/article/${article.slug}`} class="btn-ink">Open the annotated version →</a>
              <a href="/feed" class="btn-outline">Browse all papers</a>
            </div>
            <p style="margin-top:14px; font-family:var(--mono); font-size:11px; color:var(--ink-faint);">The annotated version adds the source PDF, a quick quiz, and member notes.</p>
          </div>

          <div class="lmside right" style="padding-top:40px;">
            <div class="mn-card" data-reveal>
              <div class="row gap-8" style="align-items:center; margin-bottom:6px;">
                <span class="mn-avatar" style="width:22px; height:22px; font-size:9px; background:var(--accent);">{reviewerInitials}</span>
                <span style="font-family:var(--mono); font-size:10px; color:var(--ink-soft); flex:1;">{article.reviewer_name ?? "Marginalia team"}</span>
                <span style="font-family:var(--mono); font-size:8px; letter-spacing:.1em; padding:2px 5px; color:var(--accent); border:1px solid rgba(194,65,12,.4);">TEAM</span>
              </div>
              <div class="mn-body">Today's pick. We read the whole paper so you get it in plain language.</div>
            </div>
            <MarginNote variant="hand">↑ this is why we picked it today.</MarginNote>
            <MarginNote variant="why" tilt="r" label="The point">{article.is_ai4good === 1 ? "AI aimed at a real problem: health, climate, learning, access." : "a building-block idea worth getting right."}</MarginNote>
          </div>
        </section>
      </Fragment>
    ) : (
      <div class="scrap" style="max-width:560px; margin:10px auto;">
        <h2>No pick yet today</h2>
        <p class="hook">The morning pipeline hasn't published a paper yet. Browse <a href="/feed">the feed</a> in the meantime.</p>
      </div>
    )}
  </Sheet>
</BaseLayout>
