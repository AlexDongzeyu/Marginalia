---
/**
 * Home — "The Front Page". The annotated intro is where the concept lands.
 * Data-driven from D1 (Article of the Day + latest), wrapped in the paper sheet
 * with living margins.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import MarginRow from "../components/MarginRow.astro";
import MarginNote from "../components/MarginNote.astro";
import TornDivider from "../components/TornDivider.astro";
import { getArticleOfDay, getLatestArticles } from "../lib/db";

const { env } = Astro.locals.runtime;
const [today, latest] = await Promise.all([
  getArticleOfDay(env.DB),
  getLatestArticles(env.DB, 4),
]);

const todayDate = new Date().toLocaleDateString("en-US", { month: "short", day: "numeric" });
const issueNo = Math.floor((Date.now() - Date.UTC(2024, 0, 1)) / 86_400_000);
const diffClass = (d: string) =>
  d === "Beginner" ? "tag-beginner" : d === "Advanced" ? "tag-advanced" : "tag-intermediate";
---

<BaseLayout bodyClass="page-home">
  <Sheet>
    <Masthead
      title="Marginalia"
      tagline="Notes on the AI research that matters."
      top={`Vol. I · No. ${issueNo}`}
      bottom="A student-run reading room · est. 2024"
    />

    <!-- ANNOTATED INTRO -->
    <MarginRow>
      <Fragment slot="left">
        <MarginNote variant="hand" anchor="who">
          yes — a 16-year-old started this. no, we don't bite. <span class="mn-arrow">↘</span>
        </MarginNote>
        <MarginNote variant="hand" anchor="matters">
          we read the papers so you don't have to. <span style="font-style:italic;">(yet.)</span> <span class="mn-arrow">↘</span>
        </MarginNote>
      </Fragment>

      <div class="read">
        <div class="section-label">What this is</div>
        <p>
          Marginalia is a daily, plain-language guide to
          <span class="anchor" data-anchor="matters">the AI research that actually matters</span>.
          Every day we pick one paper worth understanding, read it properly, and
          <span class="anchor" data-anchor="margins">explain it in the margins</span> — the jargon,
          the stakes, and the occasional joke.
        </p>
        <p>
          No PhD required. You bring the curiosity; we bring
          <span class="anchor" data-anchor="who">the red pen</span> — and once you understand
          something, you can annotate it for the next person.
        </p>
        <div class="cta-row">
          <a href="/today" class="btn-ink">Read today's paper →</a>
          <a href="/map" class="btn-outline">Explore the map</a>
        </div>
      </div>

      <Fragment slot="right">
        <MarginNote variant="def" anchor="margins" taped={true} tilt="l">
          <b>marginalia</b> (n.) — notes scribbled in the margins of a book. here, the whole point.
        </MarginNote>
        <MarginNote variant="member" anchor="member" initials="AK">
          a member left this → "the red pen is my favorite part fr"
        </MarginNote>
      </Fragment>
    </MarginRow>

    <TornDivider variant="a" />

    <!-- TODAY'S MARGIN -->
    <MarginRow>
      <Fragment slot="left">
        <MarginNote variant="hand">
          today's pick. updated every morning before school. <span class="mn-arrow">↘</span>
        </MarginNote>
      </Fragment>

      <div>
        <div class="section-label">Today's Margin — {todayDate}</div>
        {today ? (
          <div class="scrap">
            <svg class="clip" width="34" height="64" viewBox="0 0 34 64"><path d="M17 8 C9 8 7 14 7 22 L7 46 C7 55 13 58 18 58 C24 58 28 53 28 46 L28 18 C28 13 24 11 21 11 C17 11 14 14 14 19 L14 44" fill="none" stroke="#9aa0a6" stroke-width="3.4" stroke-linecap="round"></path></svg>
            <div class="scrap-tags">
              {today.directions?.[0] && <span class={`tag tag-lm`}>{today.directions[0].name}</span>}
              <span class={`tag ${diffClass(today.difficulty)}`}>{today.difficulty}</span>
              <span class="tag">{today.read_minutes} min read</span>
            </div>
            <h2>{today.plain_title}</h2>
            <p class="orig">orig. “{today.original_title}”{today.authors[0] ? ` · ${today.authors[0]}${today.authors.length > 1 ? " et al." : ""}` : ""}</p>
            <p class="hook">{today.hook}</p>
            <a href={`/article/${today.slug}`} class="more">Read the annotated version →</a>
          </div>
        ) : (
          <div class="scrap"><h2>No pick yet today</h2><p class="hook">Check back this morning — or browse <a href="/feed">the feed</a>.</p></div>
        )}
      </div>

      <Fragment slot="right">
        {today && (
          <MarginNote variant="why" anchor="why" tilt="r">
            {today.is_ai4good === 1
              ? "real-world stakes: this is AI pointed at a problem that actually matters."
              : "a chatbot you can actually trust is one that knows what it doesn't know."}
          </MarginNote>
        )}
        <MarginNote variant="hand">
          ↖ pass the 3-question quiz on this one and you get the <span class="mn-arrow">+10 stamp</span>
        </MarginNote>
      </Fragment>
    </MarginRow>

    <TornDivider variant="b" />

    <!-- WHAT WE DO -->
    <MarginRow>
      <div>
        <div class="section-label" style="text-align:center;">What we do</div>
        <div class="torn-cards">
          <div class="torn-card" data-reveal>
            <div class="roman">i.</div>
            <h3>Read</h3>
            <p>One paper a day, explained in the margins. No jargon left undefined.</p>
          </div>
          <div class="torn-card" data-reveal>
            <div class="roman">ii.</div>
            <h3>Learn</h3>
            <p>Pass quizzes, earn stamps, climb the leaderboard with your chapter.</p>
          </div>
          <div class="torn-card" data-reveal>
            <div class="roman">iii.</div>
            <h3>Build</h3>
            <p>Write your own marginalia. Edit it, keep a copy, help the next reader.</p>
          </div>
        </div>
      </div>
      <Fragment slot="right">
        <MarginNote variant="hand">
          ↖ understand it before you annotate it. the quiz is the gate.
        </MarginNote>
      </Fragment>
    </MarginRow>

    <TornDivider variant="c" />

    <!-- LATEST ANNOTATIONS -->
    <MarginRow>
      <Fragment slot="left">
        <MarginNote variant="hand">
          the archive grows by one every day. <span class="mn-arrow">↘</span>
        </MarginNote>
      </Fragment>
      <div>
        <div class="section-label">Latest annotations</div>
        {latest.map((a) => (
          <a class="note-row" href={`/article/${a.slug}`} data-reveal>
            <span class="date">{a.published_at || a.published_date ? new Date(a.published_at ?? a.published_date!).toLocaleDateString("en-US", { month: "short", day: "numeric" }) : ""}</span>
            <span class="nr-main">
              <span class="title">{a.plain_title}</span><br />
              <span class="meta">{[a.directions?.[0]?.name, a.difficulty].filter(Boolean).join(" · ")}</span>
            </span>
            <span class="arr">→</span>
          </a>
        ))}
        <a href="/feed" class="text-link" style="margin-top:18px;">Open the full archive →</a>
      </div>
      <Fragment slot="right" />
    </MarginRow>

    <!-- NEWSLETTER -->
    <section style="max-width:560px; margin:42px auto 0; padding:30px 0 6px; text-align:center;">
      <div class="ransom" aria-hidden="true">
        <span style="font-family:var(--mono); font-size:24px; background:#211C16; color:#FCFAF4; transform:rotate(-4deg);">S</span>
        <span style="font-family:var(--serif); font-size:25px; background:#FCFAF4; color:#211C16; border:1px solid var(--line-2); transform:rotate(3deg);">U</span>
        <span style="font-family:var(--mono); font-size:23px; background:#C2410C; color:#FCFAF4; transform:rotate(-2deg);">B</span>
        <span style="font-family:var(--hand); font-size:30px; background:#FCFAF4; color:#211C16; border:1px solid var(--line-2); transform:rotate(2.5deg);">s</span>
        <span style="font-family:var(--serif); font-style:italic; font-size:25px; background:#1E3A5F; color:#FCFAF4; transform:rotate(-3deg);">c</span>
        <span style="font-family:var(--mono); font-size:24px; background:#FCFAF4; color:#211C16; border:1px solid var(--line-2); transform:rotate(4deg);">R</span>
        <span style="font-family:var(--serif); font-size:25px; background:#211C16; color:#FCFAF4; transform:rotate(-1.5deg);">I</span>
        <span style="font-family:var(--mono); font-size:23px; background:#FCFAF4; color:#211C16; border:1px solid var(--line-2); transform:rotate(2deg);">B</span>
        <span style="font-family:var(--serif); font-style:italic; font-size:25px; background:#C2410C; color:#FCFAF4; transform:rotate(-3.5deg);">e</span>
      </div>
      <p style="margin:0 auto 18px; max-width:380px; font-size:18px; line-height:1.5; color:var(--ink-soft); font-style:italic;">
        One short letter each week — the papers worth your weekend, in plain language.
      </p>
      <form id="homeSubscribe" style="display:flex; gap:8px; justify-content:center; max-width:400px; margin:0 auto;">
        <input type="email" name="email" required placeholder="you@school.edu" class="paper-input" style="flex:1;" aria-label="Email" />
        <button type="submit" class="btn-ink">Join</button>
      </form>
      <p style="margin:14px 0 0; font-family:var(--mono); font-size:10px; letter-spacing:.04em; color:var(--ink-faintest);">no spam · unsubscribe in one click · we're 17, we get it</p>
    </section>
  </Sheet>

  <script>
    const form = document.getElementById("homeSubscribe") as HTMLFormElement | null;
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const email = (form.elements.namedItem("email") as HTMLInputElement).value;
      const res = await fetch("/api/subscribe", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });
      const data = await res.json().catch(() => ({}));
      form.innerHTML = `<p style="font-family:var(--hand); font-size:24px; color:#2E6B36;">${
        res.ok ? "✓ you're on the list — check your inbox!" : (data.error || "Something went wrong.")
      }</p>`;
    });
  </script>
</BaseLayout>
