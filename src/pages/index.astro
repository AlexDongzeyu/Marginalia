---
/**
 * Home, "The Front Page".
 * A calm reading column down the middle, personality in the margins, all of it
 * on one sheet of paper. Data comes from D1 (article of the day + latest).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
import MarginRow from "../components/MarginRow.astro";
import MarginNote from "../components/MarginNote.astro";
import TornDivider from "../components/TornDivider.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { getArticleOfDay, getLatestArticles } from "../lib/db";

export const prerender = false;

const { env } = Astro.locals.runtime;
const [today, latest] = await Promise.all([
  getArticleOfDay(env.DB).catch(() => null),
  getLatestArticles(env.DB, 5).catch(() => []),
]);

const now = new Date();
const todayDate = now.toLocaleDateString("en-US", {
  weekday: "long",
  month: "long",
  day: "numeric",
});
const issueNo = Math.floor((Date.now() - Date.UTC(2024, 0, 1)) / 86_400_000);

const ransom = [..."FIELD NOTES"];
---

<BaseLayout title="Marginalia · Notes on the AI research that matters">
  <Sheet>
    <Masthead
      title="Marginalia"
      tagline="Notes on the AI research that matters."
      top={`Vol. I · No. ${issueNo}`}
      bottom="A student-run reading room · est. 2024"
    />

    {/* ---- What this is ------------------------------------------------ */}
    <MarginRow>
      <div class="read drop-cap">
        <div class="section-label">What this is</div>
        <p>
          Marginalia is a daily, plain-language guide to the
          <span class="anchor" data-anchor="research">AI research</span> that
          actually matters. Each day we pick one paper worth understanding, read
          it properly, and explain it in the margins: the jargon, the stakes,
          and the occasional joke.
        </p>
        <p>
          No PhD required. You bring the curiosity; we bring the
          <span class="anchor" data-anchor="redpen">red pen</span>. Once
          something finally clicks, you can annotate it for the next person who
          shows up.
        </p>
      </div>

      <Fragment slot="right">
        <MarginNote variant="def" anchor="research" taped tilt="r" label="Def.">
          <b>research (n.)</b> the part everyone cites and almost nobody reads.
          we read it.
        </MarginNote>
        <MarginNote variant="member" anchor="redpen" initials="MK">
          a member left this: "the red pen is genuinely my favorite part."
        </MarginNote>
      </Fragment>
    </MarginRow>

    <TornDivider variant="a" />

    {/* ---- Today's margin --------------------------------------------- */}
    <MarginRow>
      <div>
        <div class="section-label">Today's Margin · {todayDate}</div>
        {today ? (
          <article class="scrap">
            <svg class="clip" width="26" height="46" viewBox="0 0 26 46" fill="none" aria-hidden="true">
              <path d="M13 4c-5 0-9 4-9 9v22c0 3.3 2.7 6 6 6s6-2.7 6-6V14"
                stroke="#7a5c3e" stroke-width="2.4" stroke-linecap="round" />
            </svg>
            {today.directions && today.directions.length > 0 && (
              <div class="scrap-tags">
                {today.directions.slice(0, 2).map((d) => (
                  <span class="tag">{d.name}</span>
                ))}
              </div>
            )}
            <p class="orig">{today.original_title}</p>
            <h2>{today.plain_title}</h2>
            <p class="hook">{today.hook}</p>
            <a class="more" href={`/article/${today.slug}`}>Read today's annotation →</a>
          </article>
        ) : (
          <article class="scrap">
            <p class="hook">
              Today's paper is still drying on the line. Check back shortly, or
              browse the full feed.
            </p>
            <a class="more" href="/feed">Browse the feed →</a>
          </article>
        )}
      </div>

    </MarginRow>

    <TornDivider variant="b" />

    {/* ---- What we do -------------------------------------------------- */}
    <MarginRow>
      <div>
        <div class="section-label">How a day works</div>
        <div class="torn-cards">
          <div class="torn-card" data-reveal>
            <div class="roman">i.</div>
            <h3>We pick one paper</h3>
            <p>From the firehose of new AI work, one paper that is worth your time.</p>
          </div>
          <div class="torn-card" data-reveal>
            <div class="roman">ii.</div>
            <h3>We read it for you</h3>
            <p>Then we rewrite it in plain language, with the jargon defined in the margins.</p>
          </div>
          <div class="torn-card" data-reveal>
            <div class="roman">iii.</div>
            <h3>You annotate it</h3>
            <p>Add your own note. The next reader learns from the margin you leave behind.</p>
          </div>
        </div>
      </div>
    </MarginRow>

    <section class="quote-beat" data-reveal>
      <p class="pullquote pullquote-center">
        One paper, understood properly, beats fifty headlines skimmed.
      </p>
    </section>

    {/* ---- Three doors ------------------------------------------------- */}
    <MarginRow>
      <div>
        <div class="section-label">Where to start</div>
        <div class="torn-cards">
          <a class="torn-card" href="/feed" data-reveal style="text-decoration:none;color:inherit;display:block;">
            <div class="roman">→</div>
            <h3>Read</h3>
            <p>Daily explainers. Every paper, made readable, no PhD required.</p>
          </a>
          <a class="torn-card" href="/learn" data-reveal style="text-decoration:none;color:inherit;display:block;">
            <div class="roman">✎</div>
            <h3>Learn</h3>
            <p>From "what is AI" to reading a paper. Interactive, no installs.</p>
          </a>
          <a class="torn-card" href="/contribute" data-reveal style="text-decoration:none;color:inherit;display:block;">
            <div class="roman">✦</div>
            <h3>Contribute</h3>
            <p>Annotate a paper or label a dataset. Anyone can help.</p>
          </a>
        </div>
        <p class="text-center" style="margin-top:14px;">
          <a class="text-link" href="/pulse">See what's hot in AI this week on Pulse →</a>
        </p>
      </div>
    </MarginRow>

    <TornDivider variant="c" />

    {/* ---- Latest annotations ------------------------------------------ */}
    <MarginRow>
      <div>
        <div class="section-label">Latest annotations</div>
        {latest.length > 0 ? (
          <div>
            {latest.map((a) => <ArticleCard article={a} />)}
            <a class="text-link" href="/feed" style="margin-top:18px;">See the full feed →</a>
          </div>
        ) : (
          <p class="read" style="color:var(--ink-soft);">
            The archive is just getting started. The first annotations land soon.
          </p>
        )}
      </div>

      <Fragment slot="right">
        <MarginNote variant="why" anchor="" tilt="l" label="Why bother">
          one good paper, properly understood, beats fifty half-read headlines.
        </MarginNote>
      </Fragment>
    </MarginRow>

    <TornDivider variant="a" />

    {/* ---- Newsletter -------------------------------------------------- */}
    <section style="max-width:var(--read-w);margin:8px auto 12px;text-align:center;">
      <div class="ransom">
        {ransom.map((ch, i) =>
          ch === " " ? (
            <span style="padding:0 4px;background:transparent;"></span>
          ) : (
            <span
              style={`background:${
                i % 3 === 0 ? "var(--ink)" : i % 3 === 1 ? "var(--accent)" : "var(--paper)"
              };color:${
                i % 3 === 2 ? "var(--ink)" : "var(--paper)"
              };font-family:${
                i % 2 === 0 ? "var(--serif)" : "var(--mono)"
              };transform:rotate(${(i % 5) - 2}deg);border:${
                i % 3 === 2 ? "1px solid var(--ink)" : "none"
              };`}
            >{ch}</span>
          )
        )}
      </div>
      <p class="read" style="font-size:18px;color:#3a342b;">
        One short letter each week: the papers worth your weekend, in plain
        language. No spam, no hype.
      </p>
      <form id="subscribe-form" style="display:flex;gap:8px;justify-content:center;align-items:stretch;max-width:420px;margin:18px auto 0;flex-wrap:wrap;">
        <input
          class="paper-input"
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          style="flex:1;min-width:200px;"
        />
        <button class="btn-ink" type="submit">Subscribe</button>
      </form>
      <p id="subscribe-msg" style="font-family:var(--mono);font-size:12px;color:var(--ok);margin-top:12px;min-height:18px;" aria-live="polite"></p>
    </section>
  </Sheet>

  <script is:inline>
    (() => {
      const form = document.getElementById("subscribe-form");
      const msg = document.getElementById("subscribe-msg");
      if (!form) return;
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = new FormData(form).get("email");
        msg.style.color = "var(--ink-soft)";
        msg.textContent = "sending...";
        try {
          const res = await fetch("/api/subscribe", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();
          if (res.ok) {
            msg.style.color = "var(--ok)";
            msg.textContent = "you are on the list. check your inbox.";
            form.reset();
          } else {
            msg.style.color = "var(--accent)";
            msg.textContent = data.error || "something went wrong.";
          }
        } catch {
          msg.style.color = "var(--accent)";
          msg.textContent = "network error, please try again.";
        }
      });
    })();
  </script>
</BaseLayout>
