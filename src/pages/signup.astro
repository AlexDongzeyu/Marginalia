---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
---
<BaseLayout title="Create account · Marginalia" bodyClass="page-signup">
  <Sheet>
    <Masthead title="Join Marginalia" tagline="Create your account to contribute." top="New member" compact={true} />
    <div style="max-width:440px; margin:0 auto;">
      <form id="signupForm" class="stack">
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" class="paper-input" required placeholder="Your name" autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" class="paper-input" required placeholder="you@school.edu" autocomplete="email" />
        </div>
        <div class="field">
          <label for="password">Password</label>
          <input id="password" name="password" type="password" class="paper-input" required minlength="8" placeholder="At least 8 characters" autocomplete="new-password" />
        </div>
        <button type="submit" class="btn-ink" style="justify-content:center;">Create account</button>
        <p id="signupStatus" style="font-family:var(--mono); font-size:11px; color:var(--accent); text-align:center; margin-top:12px;"></p>
      </form>
      <div style="text-align:center; margin-top:22px; padding-top:18px; border-top:1px solid var(--line);">
        <p class="muted" style="margin-bottom:12px;">Already have an account?</p>
        <a href="/login" class="btn-outline">Sign in</a>
      </div>
    </div>
  </Sheet>
  <script>
    const form = document.getElementById("signupForm") as HTMLFormElement;
    const status = document.getElementById("signupStatus");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (status) status.textContent = "Creating your account…";
      const data = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch("/api/auth/signup", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
        const out = await res.json();
        if (res.ok) window.location.href = "/dashboard";
        else if (status) status.textContent = out.error || "Could not create account.";
      } catch { if (status) status.textContent = "Network error, try again."; }
    });
  </script>
</BaseLayout>
