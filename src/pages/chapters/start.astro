---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Sheet from "../../components/Sheet.astro";
import Masthead from "../../components/Masthead.astro";
---
<BaseLayout title="Start a chapter — Marginalia" bodyClass="page-chapter-start">
  <Sheet>
    <Masthead title="Start a chapter" tagline="Bring Marginalia to your campus." top="Application" compact={true} />
    <div style="max-width:520px; margin:0 auto;">
      <form id="chapterForm" class="stack">
        <div class="field"><label for="cf-name">Your name</label><input id="cf-name" name="lead_name" class="paper-input" required /></div>
        <div class="field"><label for="cf-email">Email</label><input id="cf-email" name="email" type="email" class="paper-input" required /></div>
        <div class="field"><label for="cf-chapter">Chapter name</label><input id="cf-chapter" name="name" class="paper-input" placeholder="e.g. Riverside High Marginalia" required /></div>
        <div class="field"><label for="cf-region">School / region</label><input id="cf-region" name="region" class="paper-input" placeholder="City, country" required /></div>
        <div class="field"><label for="cf-why">Why do you want to start one?</label><textarea id="cf-why" name="description" class="paper-textarea" rows="4" required></textarea></div>
        <button type="submit" class="btn-ink" style="justify-content:center;">Submit application</button>
        <p id="cf-status" class="muted mt-16" style="text-align:center;"></p>
      </form>
    </div>
  </Sheet>
  <script>
    const form = document.getElementById("chapterForm") as HTMLFormElement;
    const status = document.getElementById("cf-status");
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (status) status.textContent = "Submitting…";
      const payload = Object.fromEntries(new FormData(form).entries());
      try {
        const res = await fetch("/api/chapters/apply", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) });
        const data = await res.json();
        if (res.ok) form.innerHTML = `<p class="read" style="font-family:var(--hand); font-size:26px; color:#2E6B36;">Thanks, ${"" + (payload.lead_name || "")}! Your application is in — we'll email ${"" + (payload.email || "")}.</p>`;
        else if (status) status.textContent = data.error || "Something went wrong.";
      } catch { if (status) status.textContent = "Network error — please try again."; }
    });
  </script>
</BaseLayout>
