---
/**
 * Chapter page, "a local reading room".
 * Shows the chapter, its members, and a request-to-join button. Leads get a
 * link through to their management tools. Fixes the previously dead
 * /chapters/[slug] link from the chapters directory.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Sheet from "../../components/Sheet.astro";
import Masthead from "../../components/Masthead.astro";
import { getSessionUser } from "../../lib/auth";

export const prerender = false;

const { env } = Astro.locals.runtime;
const db = env.DB;
const slug = String(Astro.params.slug ?? "").trim();

interface Chapter {
  id: number;
  slug: string;
  name: string;
  region: string | null;
  description: string;
  lead_id: number | null;
  status: string;
  created_at: string;
}

const chapter = await db
  .prepare(`SELECT * FROM chapters WHERE slug = ? LIMIT 1`)
  .bind(slug)
  .first<Chapter>()
  .catch(() => null);

const me = await getSessionUser(Astro.request.headers.get("cookie"), env, db).catch(() => null);

let members: { id: number; name: string; username: string | null }[] = [];
let isMember = false;
let alreadyRequested = false;

if (chapter) {
  try {
    const r = await db
      .prepare(
        `SELECT DISTINCT u.id, u.name, u.username FROM users u
         WHERE u.chapter_id = ?1 OR u.id IN (SELECT user_id FROM chapter_members WHERE chapter_id = ?1)
         ORDER BY u.name LIMIT 60`,
      )
      .bind(chapter.id)
      .all<{ id: number; name: string; username: string | null }>();
    members = r.results ?? [];
  } catch {
    members = [];
  }
  if (me) {
    isMember = members.some((m) => m.id === me.id);
    if (!isMember) {
      alreadyRequested = !!(await db
        .prepare(`SELECT 1 FROM chapter_join_requests WHERE chapter_id = ? AND user_id = ? AND status = 'pending' LIMIT 1`)
        .bind(chapter.id, me.id)
        .first()
        .catch(() => null));
    }
  }
}

const isLead = !!(me && chapter && (chapter.lead_id === me.id || me.role === "admin"));
const founded = chapter
  ? new Date(chapter.created_at).toLocaleDateString("en-US", { month: "long", year: "numeric" })
  : "";
---
{chapter ? (
  <BaseLayout title={`${chapter.name} · Chapters · Marginalia`} bodyClass="page-chapter">
    <Sheet>
      <Masthead title={chapter.name} tagline={chapter.region ?? "A Marginalia reading room"} top="Chapter" compact={true} />
      <div class="ch-wrap">
        <div class="ch-meta" data-reveal>
          <span class={`tag ${chapter.status === "active" ? "tag-good" : ""}`}>{chapter.status}</span>
          <span class="ch-stat"><b>{members.length}</b> {members.length === 1 ? "member" : "members"}</span>
          {founded && <span class="ch-stat">Founded {founded}</span>}
          {isLead && <a class="text-link" href="/dashboard/chapter">Manage this chapter →</a>}
        </div>

        {chapter.description && (
          <p class="ch-desc">{chapter.description.split("\n\nLead:")[0]}</p>
        )}

        <div class="section-label">Members</div>
        {members.length > 0 ? (
          <div class="ch-members" data-reveal>
            {members.map((m) => (
              <a class="ch-member" href={`/profile/${m.username ?? m.id}`}>
                <span class="ch-ava" aria-hidden="true">
                  {m.name.split(/\s+/).map((p) => p[0]).filter(Boolean).slice(0, 2).join("").toUpperCase()}
                </span>
                <span class="ch-name">{m.name}</span>
              </a>
            ))}
          </div>
        ) : (
          <p class="muted" style="font-family:var(--mono); font-size:12px;">No members listed yet.</p>
        )}

        <div class="ch-join" data-reveal>
          {!me ? (
            <p class="muted"><a href="/login">Sign in</a> to request to join this chapter.</p>
          ) : isMember ? (
            <p class="muted">You are a member of this chapter.</p>
          ) : alreadyRequested ? (
            <p class="muted">Your request to join is pending the lead's review.</p>
          ) : (
            <>
              <button id="joinBtn" class="btn-ink" type="button" data-slug={chapter.slug}>Request to join</button>
              <span id="joinMsg" class="ch-msg" aria-live="polite"></span>
            </>
          )}
        </div>
      </div>
    </Sheet>

    <script>
      const btn = document.getElementById("joinBtn");
      const msg = document.getElementById("joinMsg");
      btn?.addEventListener("click", async () => {
        const slug = (btn as HTMLElement).dataset.slug;
        (btn as HTMLButtonElement).disabled = true;
        if (msg) msg.textContent = "Sending…";
        try {
          const res = await fetch("/api/chapters/join", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ slug }),
          });
          const data = await res.json();
          if (msg) msg.textContent = res.ok ? "Request sent. The lead will review it." : data.error || "Something went wrong.";
          if (!res.ok) (btn as HTMLButtonElement).disabled = false;
        } catch {
          if (msg) msg.textContent = "Network error.";
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    </script>
  </BaseLayout>
) : (
  <BaseLayout title="Chapter not found · Marginalia" bodyClass="page-chapter">
    <Sheet>
      <Masthead title="No such chapter" tagline="It may have moved, or never existed." top="404" compact={true} />
      <p class="text-center muted" style="max-width:520px; margin:0 auto;">
        Browse <a href="/chapters">all chapters</a>, or <a href="/chapters/start">start your own</a>.
      </p>
    </Sheet>
  </BaseLayout>
)}

<style>
  .ch-wrap { max-width: 640px; margin: 0 auto; }
  .ch-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }
  .ch-stat { font-family: var(--mono); font-size: 12px; color: var(--ink-soft); }
  .ch-stat b { font-family: var(--serif); font-size: 18px; color: var(--ink); }
  .ch-desc { font-size: 17px; line-height: 1.6; color: #3a342b; text-wrap: pretty; margin: 0 0 24px; }

  .ch-members { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 28px; }
  .ch-member {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--ink);
    background: var(--card);
    border: 1px solid var(--line);
    padding: 6px 12px 6px 6px;
  }
  .ch-member:hover { border-color: var(--accent); }
  .ch-ava {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--accent-soft);
    color: var(--accent);
    font-family: var(--mono);
    font-size: 10px;
    display: grid;
    place-items: center;
  }
  .ch-name { font-family: var(--mono); font-size: 12px; }

  .ch-join {
    padding-top: 18px;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .ch-msg { font-family: var(--mono); font-size: 12px; color: var(--ink-soft); }
</style>
