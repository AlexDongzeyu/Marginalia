---
/**
 * /commons — Marginalia Commons program landing.
 * Community, chapters, and citizen science. Real chapters, real labeled data.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";

const doors = [
  { roman: "i.", title: "Chapters", body: "A reading group at a school or a city. A few people who meet, read a paper, and label some data together. Real groups, not pins on a map.", cta: "See the chapters", href: "/chapters" },
  { roman: "ii.", title: "Start one", body: "Want to run a chapter at your school? It takes a few people and a regular time. We give you the papers and the plan.", cta: "Start a chapter", href: "/chapters/start" },
  { roman: "iii.", title: "Classify", body: "Ten-minute micro-tasks that build open datasets: is this summary accurate? Which topic does this paper belong to? No experience needed.", cta: "Start classifying", href: "/contribute/classify", primary: true },
  { roman: "iv.", title: "Newsletter", body: "One short email when there's something worth your time. No spam, no daily firehose. Leave any day.", cta: "Get the newsletter", href: "/newsletter" },
];
---
<BaseLayout
  title="Marginalia Commons · Community & citizen science"
  description="Marginalia Commons is the community side: real chapters that actually meet, citizen-science labeling that builds open datasets, and the newsletter."
  bodyClass="page-commons"
>
  <Sheet>
    <Masthead title="Marginalia Commons" tagline="Community, chapters, and citizen science." compact={true} />

    <div class="pg-wrap">
      <div class="pg-grid">
        {doors.map((d) => (
          <article class="pg-card" data-reveal>
            <div class="pg-roman">{d.roman}</div>
            <h2>{d.title}</h2>
            <p class="pg-body">{d.body}</p>
            {d.primary
              ? <a class="btn-ink pg-cta" href={d.href}>{d.cta} →</a>
              : <a class="text-link pg-cta" href={d.href}>{d.cta} →</a>}
          </article>
        ))}
      </div>
    </div>
  </Sheet>
</BaseLayout>

<style>
  .pg-wrap { max-width: 720px; margin: 0 auto; }
  .pg-lede { font-size: 16px; line-height: 1.65; color: var(--ink-soft); margin: 0 0 22px; }

  .pg-role {
    background: var(--card-2);
    border: 1px solid rgba(122, 92, 62, 0.22);
    padding: 16px 18px;
    margin-bottom: 24px;
  }
  .pg-role-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .pg-role p { margin: 6px 0 0; font-size: 14.5px; line-height: 1.6; color: #3a342b; }

  .pg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .pg-card {
    background: var(--card);
    border: 1px solid var(--line);
    padding: 20px 22px 22px;
    box-shadow: 0 8px 22px -16px rgba(40, 30, 20, 0.4);
    display: flex;
    flex-direction: column;
  }
  .pg-roman {
    font-family: var(--serif);
    font-style: italic;
    font-size: 26px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 6px;
  }
  .pg-card h2 { font-size: 22px; font-weight: 500; margin: 0 0 8px; line-height: 1.1; }
  .pg-body { font-size: 14px; line-height: 1.55; color: #3a342b; margin: 0 0 14px; }
  .pg-cta { margin-top: auto; align-self: flex-start; }

  .pg-foot-cta { max-width: 560px; margin: 0 auto; }
  .pg-foot-cta p { font-size: 14.5px; line-height: 1.6; color: var(--ink-soft); margin: 8px 0 14px; }

  @media (max-width: 640px) {
    .pg-grid { grid-template-columns: 1fr; }
  }
</style>
