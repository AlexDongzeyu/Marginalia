---
/**
 * 404 — friendly not-found page that keeps the design + points back into the IA.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found — Marginalia" bodyClass="page-404">
  <div class="container" style="max-width:680px;">
    <div class="page-container text-center" style="margin-top:24px;">
      <div style="font-size:3rem;" aria-hidden="true">¶</div>
      <h1 style="font-size:2.4rem;">Lost in the margins</h1>
      <p class="prose">We couldn't find that page. Let's get you back to something useful.</p>
      <div class="row center wrap gap-12 mt-16">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/today" class="btn btn-secondary">Today's paper</a>
        <a href="/map" class="btn btn-ghost">The map</a>
      </div>
    </div>
  </div>
</BaseLayout>
