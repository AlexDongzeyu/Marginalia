---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";
---
<BaseLayout title="Not found · Marginalia" bodyClass="page-404">
  <Sheet>
    <Masthead title="Lost in the margins" tagline="We couldn't find that page." top="404" compact={true} />
    <div class="text-center" style="padding-bottom:20px;">
      <p class="read" style="max-width:46ch; margin:0 auto 18px;">That note seems to have been torn out. Let's get you back to something useful.</p>
      <div class="cta-row" style="justify-content:center;">
        <a href="/" class="btn-ink">Front page</a>
        <a href="/today" class="btn-outline">Today's paper</a>
        <a href="/map" class="btn-outline">The map</a>
      </div>
    </div>
  </Sheet>
</BaseLayout>
