---
import BaseLayout from "../layouts/BaseLayout.astro";
import Sheet from "../components/Sheet.astro";
import Masthead from "../components/Masthead.astro";

const roles = [
  { num: "i.", title: "Explainer writer", desc: "Claim an AI draft, check it against the source, make it shine." },
  { num: "ii.", title: "Map curator", desc: "Shape the research-direction taxonomy; keep it newcomer-friendly." },
  { num: "iii.", title: "Builder", desc: "Improve the site, the pipeline, or the learning tracks." },
  { num: "iv.", title: "Chapter lead", desc: "Start a chapter at your school and rally a few friends." },
];
---
<BaseLayout title="Join us · Marginalia" bodyClass="page-join">
  <Sheet>
    <Masthead title="Join the margins" tagline="No experience required, just curiosity and care." top="Help wanted" compact={true} />
    <div style="max-width:680px; margin:0 auto; display:grid; grid-template-columns:1fr 1fr; gap:14px;">
      {roles.map((r) => (
        <div class="torn-card" data-reveal>
          <div class="roman">{r.num}</div>
          <h3>{r.title}</h3>
          <p>{r.desc}</p>
        </div>
      ))}
    </div>
    <div class="scrap text-center" style="max-width:560px; margin:26px auto 0; transform:rotate(-.4deg);">
      <h2 style="font-size:24px;">Ready?</h2>
      <p class="muted">Start a chapter, or subscribe to follow along while we open more roles.</p>
      <div class="cta-row" style="justify-content:center;">
        <a href="/chapters/start" class="btn-ink">Start a chapter</a>
        <a href="/newsletter" class="btn-outline">Get the newsletter</a>
      </div>
    </div>
  </Sheet>
</BaseLayout>
